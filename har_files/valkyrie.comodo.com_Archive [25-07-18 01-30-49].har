nel-collapse collapse\" aria-expanded=\"false\">'\n                + '<div class=\"table-scrollable\">'\n                + '{0}</div></div></div>';\n\n        var tableTemplate = '<table class=\"table table-bordered table-hover\"><thead><tr class=\"uppercase\">'\n                            + '<th>Address</th>'\n                            + '<th>Ip</th>'\n                            + '<th>Latitude</th>'\n                            + '<th>Longitude</th>'\n                            + '<th>City</th>'\n                            + '<th>Region</th>'\n                            + '<th>Country</th>'\n                            + '</tr></thead><tbody id=\"ip-table-body\"></tbody></table>';\n\n        var ipRowTemplate = '<tr><td>{0}</td><td>{1}</td><td>{2}</td><td>{3}</td><td>{4}</td><td>{5}</td><td>{6}</td></tr>';\n\n        var ipPanel = String.format(biPanelTemplate, tableTemplate)\n        $(ipPanel).insertAfter(\"#bi-info-text\");\n\n        map = new google.maps.Map(document.getElementById(\"map_canvas\"), myOptions);\n        $.each(ipList, function (i, data) {\n            //console.log(ip);\n            try {\n            var marker = new google.maps.Marker({\n                position: new google.maps.LatLng(data.latitude, data.longitude),\n                map: map,\n                title: data.ip,\n                animation: google.maps.Animation.DROP,\n            });\n\n            address = data.name + \" / \" + data.ip;\n\n            var infoWindowRowTemplate = \"<tr style='text-align: left;' ><th>{0}</th><td>: {1}</td></tr>\";\n            infoWindowContent = \"<table>\";\n            infoWindowContent += infoWindowRowTemplate.format(\"Address\", address || \"\");\n            infoWindowContent += infoWindowRowTemplate.format(\"Country\", data.country_name || \"\");\n            infoWindowContent += infoWindowRowTemplate.format(\"Region\", data.region_name || \"\");\n            infoWindowContent += infoWindowRowTemplate.format(\"City\", data.city || \"\");\n            infoWindowContent += infoWindowRowTemplate.format(\"Zip Code\", data.zip_code || \"\");\n            infoWindowContent += \"</table>\";\n\n            var infowindow = new google.maps.InfoWindow({\n                content: infoWindowContent //\"<pre>\" + syntaxHighlight(data) + \"</pre>\"\n            });\n\n            google.maps.event.addListener(marker, 'click', function () {\n                infowindow.open(map, marker);\n            });\n\n            ipRow = String.format(ipRowTemplate, data.name || \"\", data.ip || \"\", data.latitude || \"\", data.longitude || \"\", data.city || \"\", data.region_name || \"\", data.country_name || \"\");\n\n            $(\"#ip-table-body\").append(ipRow);\n\n            fitMap(data.latitude, data.longitude);\n            }catch(err) {}\n        });\n    }\n\n    function fitMap(lat, long) {\n        var LatLng = new google.maps.LatLng(lat, long);\n        bounds.extend(LatLng);\n        //  Fit bounds to the map\n        centerMap()\n    }\n\n    function centerMap() {\n        //  Fit bounds to the map\n        map.setCenter(bounds.getCenter());\n        map.fitBounds(bounds);\n        google.maps.event.trigger(map,'resize')\n    }\n\n    function copyTextToClipboard() {\n          var textArea = document.createElement(\"textarea\");\n\n          // Place in top-left corner of screen regardless of scroll position.\n          textArea.style.position = 'fixed';\n          textArea.style.top = 0;\n          textArea.style.left = 0;\n\n          // Ensure it has a small width and height. Setting to 1px / 1em\n          // doesn't work as this gives a negative w/h on some browsers.\n          textArea.style.width = '2em';\n          textArea.style.height = '2em';\n\n          // We don't need padding, reducing the size if it does flash render.\n          textArea.style.padding = 0;\n\n          // Clean up any borders.\n          textArea.style.border = 'none';\n          textArea.style.outline = 'none';\n          textArea.style.boxShadow = 'none';\n\n          // Avoid flash of white box if rendered for any reason.\n          textArea.style.background = 'transparent';\n\n          host = window.location.protocol + \"//\" + window.location.hostname + (window.location.port ? ':' + window.location.port: '');\n          var path = host + \"/get_info?sha1=\" + '9b4688ba4788e34bce47d91b0accc98d33dbf8d2'\n\n          textArea.value = path;\n\n          document.body.appendChild(textArea);\n\n          textArea.select();\n\n          try {\n            var successful = document.execCommand('copy');\n            var msg = successful ? 'successful' : 'unsuccessful';\n            //console.log('Copying text command was ' + msg);\n            toastr.success(\"Successfully copied to clipboard!\", \"Copy URL to Clipboard\");\n          } catch (err) {\n            //console.log('Oops, unable to copy');\n            toastr.error(\"Unable to Copy URL\", \"Copy URL to Clipboard\");\n          }\n\n          document.body.removeChild(textArea);\n    }\n\n\n</script>\n\n<!-- END PAGE LEVEL PLUGINS -->\n\n<script src=\"/static/scripts/_upload_form.js\" type=\"text/javascript\"></script>\n</body>\n</html>"
