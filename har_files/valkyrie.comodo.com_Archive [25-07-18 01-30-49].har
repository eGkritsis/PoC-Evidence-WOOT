readonly]) ~ .form-control-focus:after {\n        height: 0px;\n    }\n    input[type=search] {\n        -webkit-appearance: textfield;\n\n    }\n\n    </style>\n    <!--End Google Analytics Tracking caret-->\n</head>\n<!-- END HEAD -->\n\n<body class=\"page-md\" style=\"min-width: 770px;\">\n<div id=\"page-div\" style=\"display: none\">\n    <div id=\"valkyrie_navbar_pdf\" class=\"page-header navbar bg-red-valkyrie\" style=\"display: none\">\n        <!-- BEGIN HEADER MENU -->\n        <div class=\"page-header-inner\">\n            <!-- BEGIN LOGO -->\n            <div class=\"page-logo\" style=\"width:270px ! important; float: left;\">\n                <a href=\"https://valkyrie.comodo.com:443\" style=\"text-decoration:none;\">\n                    <img src=\"/static/img/new_valkyrie/valkyrie_logo.png\" style=\"width: 270px;padding-top: 7px;padding-left: 40px;padding-right: 80px;padding-bottom: 12px;\" class=\"logo-default\" alt=\"valkyrie logo\"/>\n                </a>\n                <div class=\"menu-toggler sidebar-toggler\">\n\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"valkyrie_navbar\" class=\"page-header navbar navbar-fixed-top bg-red-valkyrie\">\n        <!-- BEGIN HEADER MENU -->\n        <div class=\"page-header-inner\">\n\n            \n            \n            <!-- BEGIN LOGO -->\n            <div class=\"page-logo\" style=\"width:270px ! important; float: left; border-right: 1px solid #fff;\">\n                <a href=\"https://valkyrie.comodo.com:443\" style=\"text-decoration:none;\">\n                    <img src=\"/static/img/new_valkyrie/valkyrie_logo.png\" style=\"width: 270px;padding-top: 7px;padding-left: 40px;padding-right: 80px;padding-bottom: 12px;\" class=\"logo-default\" alt=\"valkyrie logo\"/>\n                </a>\n    <!--\n                <div class=\"menu-toggler sidebar-toggler\">\n                    <a href=\"javascript:;\" class=\"menu-toggler\"></a>\n                </div>\n                -->\n                \n                <button class=\"btn bg-red-valkyrie\" style=\"position: absolute;left: 223px;top: 12px;\" onclick=\"hideAndShowSideMenu()\">\n                    <span class=\"md-click-circle md-click-animate\" style=\"height: 46px; width: 46px; top: -3px; left: 7px;\"></span>\n                    <i class=\"fa fa-bars\" aria-hidden=\"true\"></i>\n                </button>\n                \n            </div>\n            <!-- END LOGO -->\n\n            <div id=\"page_breadcrumb\" class=\"top-menu pull-left\" style=\"margin: 21px;margin-left: 30px;font-size: 12px;\">\n                \n\n                \n            </div>\n            <div class=\"top-menu pull-right\">\n\n                \n                    <ul class=\"nav navbar-nav\">\n                        <li style=\"margin: 13px;position: relative;\">\n\n                            <a id=\"uploadFileToggle\" data-toggle=\"modal\" href=\"#uploadAnotherFileModal\" class=\"btn file-analyzer\" data-container=\"body\" style=\"background-color: #9A2128; border: 0; border-radius: 5px; padding: 8px 14px 8px 5px; color: white; font-size: 13px;text-transform: capitalize;\">\n                                <i class=\"fa fa-search\" aria-hidden=\"true\"></i><span>Analyze new file</span>\n                            </a>\n                        </li>\n                    </ul>\n                <!-- USER MENU -->\n                    <ul class=\"nav navbar-nav\">\n                        \n                        \n                        \n\n                        <!-- BEGIN USER LOGIN DROPDOWN\n                        <li>\n                            <div class=\"username username-hide-mobile\" style=\"height: 60px;color:white;background-color: transparent;text-align: right;padding: 18px;font-size: 14px;\">\n                                Evgenios Gkritsis\n                            </div> -->\n                        <li class=\"dropdown dropdown-user dropdown-light\" style=\