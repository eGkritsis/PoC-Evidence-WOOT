                    aria-expanded=\"true\">\n\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n            </div>\n            <!-- BEGIN PAGE CONTENT -->\n        </div>\n    </div>\n\n    <!-- BEGIN FOOTER -->\n    <div id=\"valkyrie_footer\" class=\"page-footer bg-red-valkyrie\" style=\"position: relative;\">\n        <div class=\"container\">&copy; Valkyrie, Comodo Security Solutions, Inc. 2025. All rights reserved. v1.49.0-72-ENT\n        <div class=\"font-red-flamingo pull-right\"><small>ip-10-10-10-142</small></div></div>\n    </div>\n    <!-- END FOOTER -->\n</div>\n<!-- BEGIN PAGE LEVEL CONTENT -->\n\n<div id=\"uploadAnotherFileModal\" class=\"modal fade bs-modal-lg\" tabindex=\"-1\">\n    <div class=\"modal-dialog modal-lg\" style=\"width:760px;\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-hidden=\"true\"></button>\n                <h4 class=\"modal-title\">Analyze File</h4>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"row\">\n                    <div class=\"col-md-12\">\n                        <form role=\"form\" enctype=\"multipart/form-data\" action=\"/get_info?sha1=\" method=\"get\">\n\n    <div id=\"search_sha1\" class=\"form-group form-md-line-input\">\n        <div class=\"row\">\n            <div class=\"col-xs-10 col-sm-10 col-md-10\">\n                <div class=\"input-group\" style=\"width: 100%;\">\n                    <input id=\"sha1\" name=\"sha1\" type=\"text\" class=\"form-control edited\" placeholder=\"SHA1\" required style=\"padding-left: 5px;border: 1px solid #E5EAED;cursor: default\">\n                    <label for=\"fileName\" style=\"font-weight: 600;color: black;\">Analyze with SHA1:</label>\n                </div>\n            </div>\n            <div class=\"col-xs-2 col-sm-2 col-md-2\">\n                <span class=\"input-group-btn btn-right\">\n                    <button id=\"search-sha1-button\" class=\"btn mobile-btn bg-red-valkyrie pull-right\" style=\"width: 100px;border-radius: 5px;text-transform: capitalize;\" type=\"submit\"><i class=\"fa fa-search\" aria-hidden=\"true\"></i>  Search</button>\n                </span>\n            </div>\n        </div>\n    </div>\n</form>\n\n<form role=\"form\" enctype=\"multipart/form-data\" action=\"/fvs_url\" method=\"post\" onsubmit=\"showLoader('Loading...')\">\n\n    <div id=\"file-path-upload-div\" class=\"form-group form-md-line-input\">\n        <div class=\"row\">\n            <div class=\"col-xs-10 col-sm-10 col-md-10\">\n                <div class=\"input-group\" style=\"width: 100%;\">\n                    <input id=\"fileURL\" name=\"fileURL\" type=\"text\" class=\"form-control edited\" placeholder=\"File Url\" required style=\"padding-left: 5px;border: 1px solid #E5EAED;cursor: default\">\n                    <label for=\"fileName\" style=\"font-weight: 600;color: black;\">Analyze with File URL:</label>\n                </div>\n            </div>\n            <div class=\"col-xs-2 col-sm-2 col-md-2\">\n                <span class=\"input-group-btn btn-right\">\n                    <button id=\"file-url-button\" class=\"btn mobile-btn bg-red-valkyrie pull-right\" style=\"width: 100px;border-radius: 5px;text-transform: capitalize;\" type=\"submit\"><i class=\"fa fa-link\"></i>  Analyze</button>\n                </span>\n            </div>\n        </div>\n    </div>\n\n</form>\n\n<form id=\"file_upload_form\" role=\"form\" enctype=\"multipart/form-data\" action=\"/upload/file/\" method=\"post\" onsubmit=\"showLoader('Loading...')\">\n    <div id=\"file-upload-div\"  style=\"margin-bottom: 10px !important;\" class=\"form-group form-md-line-input\">\n        <div class=\"row\" style=\"margin-bottom: 10px\">\n            <div class=\"col-xs-8 col-sm-8 col-md-8\" style=\"margin-bottom: 10px;\">\n                <div class=\"input-group\" style=\"width: 100%;\">\n                    <input onclick=\"document.getElementById('filepc').click()\"  id=\"fileName\" name=\"fakefilepc\" type=\"text\" class=\"form-control edited\" disabled placeholder=\"Please Select a File\" required style=\"padding-left: 5px;border: 1px solid #E5EAED;cursor: default\">\n                    <label for=\"fileName\" style=\"font-weight: 600;color: black;\">Analyze with File Upload:</label>\n                    <span id=\"infoLabel\" class=\"help-block\"></span>\n                </div>\n            </div>\n            <div class=\"col-xs-4 col-sm-4 col-md-4\">\n            <span class=\"input-group-btn btn-right\">\n                <button id=\"select-file-button\" class=\"btn mobile-btn bg-red-valkyrie\" style=\"width: 100px;border-radius: 5px;text-transform: capitalize;\" type=\"button\" onclick=\"document.getElementById('filepc').click()\" >\n                    <i class=\"fa fa-file\"></i>  Select File\n                </button>\n                <input id=\"filepc\" type=\"file\" name=\"userfile\" style=\"position: absolute; bottom:10px; left:40px; z-index: -1;\" required/>\n            </span>\n\n            <span class=\"input-group-btn btn-right\">\n                <button id=\"file-upload-button\" class=\"btn mobile-btn bg-red-valkyrie pull-right\" style=\"width: 100px;border-radius: 5px;text-transform: capitalize;\" type=\"submit\">\n                    <i class=\"fa fa-upload\"></i>  Analyze\n                </button>\n            </span>\n            </div>\n        </div>\n        <a href=\"/file_upload_criteria\" style=\"color: #337ab7; text-decoration: none;\" target=\"_blank\">File Upload Criteria</a>\n    </div>\n\n    <div class=\"form-group\">\n        <div class=\"row\">\n            <div class=\"col-md-4\">\n                <h6><strong>Max File Size is <span id=\"max-limit-div\"></span>.</strong></h6>\n            </div>\n        </div>\n        <div class=\"row\">\n            <div class=\"col-md-12\">\n                <h6><strong>Analyze Multiple File with Threat Hunter Assessment Tool</strong></h6>\n            </div>\n        </div>\n        <div class=\"row\">\n            <div class=\"col-md-12\">\n                <a href=\"/apt_tool/download/ThreatHunterAssessmentTool.exe\" style=\"border-radius: 5px;\" class=\"btn bg-red-valkyrie pull-left\"><i class=\"fa fa-cloud-download\"></i> Download Threat Hunter Assessment Tool</a>\n            </div>\n        </div>\n    </div>\n</form>\n\n                    </div>\n                </div>\n            </div>\n            <div class=\"modal-footer\"></div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n<!-- END UPLOAD FILE MODAL -->\n\n<div id=\"objectModal\" class=\"modal fade\" tabindex=\"-1\">\n    <div class=\"modal-dialog modal-lg\" style=\"width:760px;\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-hidden=\"true\"></button>\n                <h4 class=\"modal-title\">Object Manual Analysis Result</h4>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"row\">\n                    <div class=\"col-md-12\">\n                        <form id=\"object_to_human_expert_form\" role=\"form\" enctype=\"multipart/form-data\" method=\"post\"\n                              action=\"/fvs_object_to_verdict/9b4688ba4788e34bce47d91b0accc98d33dbf8d2\">\n                            <div id=\"object\" class=\"form-group form-md-line-input\">\n                                <div class=\"row\">\n                                    <div class=\"col-xs-8 col-sm-8 col-md-8\">\n                                        <div class=\"input-group\">\n                                        <span class=\"input-group-addon\">\n                                        </span>\n                                            <input id=\"comment\" name=\"comment\" type=\"text\" class=\"form-control edited\" placeholder=\"Comment(Optional)\">\n                                            <label for=\"comment\">Comment:</label>\n                                        </div>\n                                    </div>\n                                    <div class=\"col-xs-4 col-sm-4 col-md-4\">\n                                        <span class=\"input-group-btn btn-right\">\n                                            <button id=\"object-button\" class=\"btn mobile-btn green pull-right\" type=\"submit\">OBJECT</button>\n                                        </span>\n                                        <span class=\"input-group-btn btn-right\">\n                                            <button id=\"cancel-button\" class=\"btn mobile-btn green pull-right\" type=\"button\" data-dismiss=\"modal\">CANCEL</button>\n                                        </span>\n                                    </div>\n                                </div>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n            </div>\n            <div class=\"modal-footer\"></div>\n        </div>\n    </div>\n</div>\n\n\n<div id=\"killchainModal\" class=\"modal fade\" tabindex=\"-1\">\n    <div class=\"modal-dialog modal-lg\" style=\"width:760px;\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-hidden=\"true\"></button>\n                <h4 class=\"modal-title\">Send to Kill Chain Analysis</h4>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"row\">\n                    <div class=\"col-md-12\">\n                        <form id=\"send_to_kill_chain_form\" role=\"form\" enctype=\"multipart/form-data\" method=\"post\"\n                              action=\"/submit/kill/chain/analysis/9b4688ba4788e34bce47d91b0accc98d33dbf8d2\">\n                            <div id=\"killchain\" class=\"form-group form-md-line-input\">\n                                <div class=\"row\">\n                                    <div class=\"col-xs-9 col-sm-9 col-md-9\">\n                                        <div class=\"input-group\">\n                                            <label for=\"comment\">Are you sure you want to send file to Kill-Chain Analysis ?</label>\n                                        </div>\n                                    </div>\n                                    <div class=\"col-xs-3 col-sm-3 col-md-3\">\n                                        <span class=\"input-group-btn btn-right\">\n                                            <button id=\"killchain-send-button\" class=\"btn mobile-btn green pull-right\" type=\"submit\">SEND</button>\n                                        </span>\n                                        <span class=\"input-group-btn btn-right\">\n                                            <button id=\"killchain-cancel-button\" class=\"btn mobile-btn green pull-right\" type=\"button\" data-dismiss=\"modal\">CANCEL</button>\n                                        </span>\n                                    </div>\n                                </div>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n            </div>\n            <div class=\"modal-footer\"></div>\n        </div>\n    </div>\n</div>\n\n\n<div class=\"modal fade\" id=\"re_analyze_modal\" tabindex=\"-1\" role=\"basic\" aria-hidden=\"true\" data-width=\"760\">\n    <div class=\"modal-dialog\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-hidden=\"true\"></button>\n                <h4 class=\"modal-title\">File already analyzed by Valkyrie @ <span id=\"last_analysis_date\">--</span></h4>\n            </div>\n            <div class=\"modal-body\">\n                <p>SHA1:<span id=\"sha1_text\">--</span></p>\n            </div>\n            <div class=\"modal-footer\">\n                <button type=\"button\" class=\"btn default\" data-dismiss=\"modal\" onclick=\"viewLastResult()\">View Last Result</button>\n                <button type=\"button\" class=\"btn blue\" data-dismiss=\"modal\" onclick=\"reAnalyze()\">Re-Analyze File</button>\n            </div>\n        </div>\n        <!-- /.modal-content -->\n    </div>\n    <!-- /.modal-dialog -->\n</div>\n<div class=\"modal fade\" id=\"re_analyze_modal_2\" tabindex=\"-1\" role=\"basic\" aria-hidden=\"true\" data-width=\"760\">\n    <div class=\"modal-dialog\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-hidden=\"true\"></button>\n                <h4 class=\"modal-title\">File already analyzed by Valkyrie @ <span id=\"last_analysis_date_2\">--</span></h4>\n            </div>\n            <div class=\"modal-body\">\n                <p>SHA1:<span id=\"sha1_text_2\">--</span></p>\n            </div>\n            <div class=\"modal-footer\">\n                <button type=\"button\" class=\"btn default\" data-dismiss=\"modal\" onclick=\"viewLastResult_2('9b4688ba4788e34bce47d91b0accc98d33dbf8d2')\">View Last Result</button>\n                <button type=\"button\" class=\"btn blue\" data-dismiss=\"modal\" onclick=\"reAnalyze_2('9b4688ba4788e34bce47d91b0accc98d33dbf8d2')\">Re-Analyze File</button>\n            </div>\n        </div>\n        <!-- /.modal-content -->\n    </div>\n    <!-- /.modal-dialog -->\n</div>\n<!-- END FOOTER -->\n\n\n\n<div class=\"leftcurtain\"></div>\n<div class=\"rightcurtain\"></div>\n<div class=\"loader-container loader-wrapper\">\n    <div class=\"contener_general\">\n        <div class=\"contener_mixte\">\n            <div class=\"ballcolor ball_1\">&nbsp;</div>\n        </div>\n        <div class=\"contener_mixte\">\n            <div class=\"ballcolor ball_2\">&nbsp;</div>\n        </div>\n        <div class=\"contener_mixte\">\n            <div class=\"ballcolor ball_3\">&nbsp;</div>\n        </div>\n        <div class=\"contener_mixte\">\n            <div class=\"ballcolor ball_4\">&nbsp;</div>\n        </div>\n    </div>\n    <div id=\"loader-text\" class=\"label loading-text\"><strong>Loading...</strong></div>\n</div>\n<!-- BEGIN JAVASCRIPTS(Load javascripts at bottom, this will reduce page load time) -->\n<!-- BEGIN CORE PLUGINS -->\n<!--[if lt IE 9]>\n<script src=\"/static/global/plugins/respond.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/excanvas.min.js\" type=\"text/javascript\"></script>\n<![endif]-->\n<script src=\"/static/global/plugins/jquery.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/jquery-migrate.min.js\" type=\"text/javascript\"></script>\n<!-- IMPORTANT! Load jquery-ui.min.js before bootstrap.min.js to fix bootstrap tooltip conflict with jquery ui tooltip -->\n<script src=\"/static/global/plugins/jquery-ui/jquery-ui.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/bootstrap/js/bootstrap.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/bootstrap-hover-dropdown/bootstrap-hover-dropdown.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/bootbox/bootbox.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/scripts/prototypes.js?v=1.49.0-72-ENT\" type=\"text/javascript\"></script>\n<!-- END CORE PLUGINS -->\n<script src=\"/static/global/scripts/metronic.js\" type=\"text/javascript\"></script>\n<script src=\"/static/scripts/layout.js?v=1.49.0-72-ENT\" type=\"text/javascript\"></script>\n<script src=\"/static/scripts/new_datetimepicker_layout.js\" type=\"text/javascript\"></script>\n\n<script src=\"/static/global/plugins/sha1_calculator/sha1.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/sha1_calculator/sha1-min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/sha1_calculator/lib-typedarrays-min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/sha1_calculator/aes.js\" type=\"text/javascript\"></script>\n\n\n\n\n<script>\n\n    var analysisNewFile = $('#uploadFileToggle>span').text();\n    var username = $('.username.username-hide-mobile').text();\n\n    function sidebarCloseCallback() {\n\n            $( \"#page-content-div\" ).removeClass( \"paddingLeft280\", 0 );\n\n    };\n    function sidebarOpenCallback() {\n\n           $( \"#page-content-div\" ).addClass( \"paddingLeft280\", 0 );\n\n    };\n\n    \n    var w = 0;\n    $( window ).load( function(){\n        w = $( window ).width();\n        if( w< 995){\n            $( \".page-sidebar-wrapper\" ).hide( 'slide',{}, 0, sidebarCloseCallback);\n            $('#uploadFileToggle>span').text('');\n            $('.username.username-hide-mobile').text('');\n            $('#page_breadcrumb').hide();\n\n        }else{\n            $( \".page-sidebar-wrapper\" ).show( 'slide',{}, 0, sidebarOpenCallback);\n            $('#uploadFileToggle>span').text(analysisNewFile);\n            $('.username.username-hide-mobile').text(username);\n            $('#page_breadcrumb').show();\n        }\n    });\n\n    $( window ).resize( function(){\n        if( w != $( window ).width() ){\n            w = $( window ).width();\n        }\n        if( w< 995){\n            $( \".page-sidebar-wrapper\" ).hide( 'slide',{}, 0, sidebarCloseCallback);\n            $('#uploadFileToggle>span').text('');\n            $('.username.username-hide-mobile').text('');\n            $('#page_breadcrumb').hide();\n\n        }else{\n            $( \".page-sidebar-wrapper\" ).show( 'slide',{}, 0, sidebarOpenCallback);\n            $('#uploadFileToggle>span').text(analysisNewFile);\n            $('.username.username-hide-mobile').text(username);\n            $('#page_breadcrumb').show();\n        }\n    });\n    \n\n    function hideAndShowSideMenu(){\n        if($(\"#page-content-div\").hasClass( \"paddingLeft280\" )){\n            $( \".page-sidebar-wrapper\" ).hide( 'slide',{}, 0, sidebarCloseCallback);\n        }else{\n            $( \".page-sidebar-wrapper\" ).show( 'slide',{}, 0, sidebarOpenCallback);\n        }\n    }\n    $( \"#page-content-div\" ).hasClass( \"paddingLeft280\" );\n\n    jQuery(document).ready(function() {\n        Metronic.init(); // init metronic core components\n        Layout.init(); // init current layout\n        updateTimes();\n        //remove duplicate dividers\n        $(\"li .divider\").each(function( index ) {\n            if ($( this ).next().hasClass(\"divider\"))\n                {\n                    $(this).remove()\n                }\n            });\n\n        \n        \n        \n    });\n\n    function decodeCompURI(data)\n    {\n        data = '' + data;\n        try {\n            data = decodeURIComponent(data);\n        }\n        catch(err) {\n            data=data;\n        }\n        return data;\n    }\n\n    function updateTimes()\n    {\n        $(\".to-local-date\").each(function(){\n            $(this).text(convertToLocalDate($(this).text()));\n        });\n\n        $(\".to-pretty-time\").each(function(){\n            $(this).text(prettifyTime($(this).text()));\n        });\n\n        $(\"time.timeago\").each(function(){\n            $(this).attr(\"datetime\", convertToLocalDate($(this).attr(\"datetime\")));\n            $(this).attr(\"title\", convertToLocalDate($(this).attr(\"title\")));\n        });\n        \n\n        $(\".url-decode\").each(function(){\n            $(this).text(decodeCompURI($(this).text()));\n            $(this).attr('data-original-title', decodeCompURI($(this).text()))\n        });\n    }\n\n    function convertToLocalDateByDate(d)\n    {\n       year = d.getFullYear();\n       month = d.getMonth() + 1;\n       day = d.getDate();\n       hour = d.getHours();\n       min = d.getMinutes();\n       sec = d.getSeconds();\n       return \"{0}-{1}-{2} {3}:{4}:{5}\".format(year, pad(month, 2), pad(day, 2), pad(hour, 2), pad(min, 2), pad(sec, 2));\n    }\n\n    function prettifyTime(timeInMinutes)\n    {\n        timeInMinutes = parseInt(timeInMinutes)\n        days = parseInt(timeInMinutes/60/24)\n        hours = parseInt((timeInMinutes - days*60*24)/60);\n        minutes = parseInt((timeInMinutes - days*60*24 - hours*60));\n        if (days != 0) {\n            return days + \" d \" + hours + \" h \" + minutes + \" m\"\n        }\n        else if (hours != 0) {\n            return hours + \" h \" + minutes + \" m\"\n        }\n        else if (minutes != 0)\n        {\n            return minutes + \" m\"\n        }\n        else\n        {\n            return \"-\"\n        }\n    }\n\n    function convertToLocalDate(datetime)\n    {\n        if(datetime != null && datetime != \"\" && datetime.indexOf(\"None\") == -1 && datetime.indexOf(\"NaN\") == -1){\n\n            if(datetime.indexOf(\".\") === -1){\n                return datetime;\n            }\n\n            validDate = datetime.split(\".\")[0].replace(/-/g,'/').replace('T', ' ');\n\n            \n            var d = new Date(validDate + \" UTC\");\n            return convertToLocalDateByDate(d);\n            \n        }\n        else\n            return \"\";\n    }\n\n    function convertToLocalDatetime(datetime)\n    {\n        if(datetime != null && datetime != \"\" && datetime.indexOf(\"None\") == -1 && datetime.indexOf(\"NaN\") == -1){\n\n            if(datetime.indexOf(\".\") === -1){\n                return datetime;\n            }\n\n            validDate = datetime.split(\".\")[0].replace(/-/g,'/').replace('T', ' ');\n\n            return new Date(validDate + \" UTC\");\n        }\n        else\n            return null;\n    }\n\n    function showLoader(text)\n    {\n        $('body').scrollTop(0);\n        $(\"body\").css(\"overflow\", \"hidden\")\n        $(\".leftcurtain\").stop().animate({width:'50%'}, 300 );\n        $(\".rightcurtain\").stop().animate({width:'50%'}, 300 );\n        $(\".loader-container\").show();\n        $(\".loader-container\").css(\"opacity\", 1);\n        $(\"#loader-text\").text(text);\n\n        return true;\n    }\n\n    function hideLoader()\n    {\n        setTimeout(function(){\n            $(\"#page-div\").show();\n            $(\".leftcurtain\").stop().animate({width:'0px'}, 300);\n            $(\".rightcurtain\").stop().animate({width:'0px'}, 300);\n            $(\".loader-container\").css(\"opacity\", 0);\n            $(\".loader-container\").delay(300).hide();\n            checkContentHeight();\n        }, 200);\n\n        return true;\n    }\n\n    height_init = false\n    function checkContentHeight(){\n        var height;\n        height = Metronic.getViewPort().height -\n            $('.page-header').outerHeight() -\n            $('.page-footer').outerHeight();\n        /*\n        height = Metronic.getViewPort().height -\n            $('.page-header').outerHeight() -\n            ($('.page-container').outerHeight() - $('.page-content').outerHeight()) -\n            $('.page-prefooter').outerHeight() -\n            $('.page-footer').outerHeight();\n        */\n\n        $('.page-content').css('min-height', height);\n    }\n\n    function insert_activity_log(sha1, log_type) {\n        $.ajax({\n        method: \"POST\",\n        url: \"/insert/user/event\",\n        data: { \"log_type\": log_type, \"sha1\": sha1 }\n        })\n        .done(function( msg ) {\n        });\n    }\n\n    function remove_empty_tables_and_portlets(){\n        $('table').each(function() {\n          if($(this).find('td').length == 0 && $(this).hasClass(\"removable\")) {\n           $(this).remove();\n          }\n        });\n\n        $('.portlet-body').each(function() {\n        if ($(this).text().trim() == \"\" && $(this).html().trim() == \"\")\n            {\n                $(this).parent(\".portlet\").remove();\n            }\n        });\n    }\n\n\n\n\n</script>\n\n<!-- BEGIN PAGE LEVEL PLUGINS -->\n\n<script src=\"/static/global/plugins/bootstrap-toastr/toastr.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/bootstrap-modal/js/bootstrap-modalmanager.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/bootstrap-modal/js/bootstrap-modal.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/jquery.timeago.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/jquery.velocity.min.js\" type=\"text/javascript\"></script>\n<script src=\"/static/global/plugins/jstree/dist/jstree.min.js\" type=\"text/javascript\"></script>\n\n<script type=\"text/javascript\" src=\"//cdnjs.cloudflare.com/ajax/libs/socket.io/1.3.6/socket.io.min.js\"></script>\n<!--<script src=\"/static/global/plugins/socket.io.min.js\" type=\"text/javascript\"></script>-->\n<script type=\"text/javascript\" src=\"https://maps.google.com/maps/api/js?sensor=false\"></script>\n\n\n<script>\nvar Send_to_Kill_Chain_Analysis = false;\nvar Kill_Chain_report_is_being_created = false;\nvar Kill_chain_ready = false;\nvar Copy_URL_to_Clipboard = false;\nvar View_Virus_Total_Result = false;\nvar Object_to_Human_Expert_Analysis_Verdict = false;\nvar Send_to_Human_Expert_Analysis = false;\nvar Human_Expert_Is_In_Progress = false;\nvar No_Manual_Analysis_Report = false;\nvar Download_Human_Expert_Analysis_Report = false;\nvar Download_Pcap_File = false;\nvar Export_Results_to_PDF = false;\nvar Analyze_Again = false;\nvar file_info_sha1 = \"9b4688ba4788e34bce47d91b0accc98d33dbf8d2\";\nvar file_info_sha256 = \"3c52178c27d2a0336f6286f6cf0a4a253a507273b1a19303edcacb39d2659a4b\";\nvar ign_file = false;\n\n\n\n\n\n\n\n\n  \n\n  \n    Copy_URL_to_Clipboard = true;\n  \n\n  \n    View_Virus_Total_Result = true;\n  \n\n  \n\n  \n\n      \n        Human_Expert_Is_In_Progress = true;\n      \n\n  \n\n  \n\n  \n    Export_Results_to_PDF = true;\n  \n\n  \n\n\n    function table_action_menu_function(sha256,sha1, Export_Results_to_PDF, View_Virus_Total_Result, Send_to_Kill_Chain_Analysis, Kill_Chain_report_is_being_created,\n        Kill_chain_ready, Send_to_Human_Expert_Analysis, Download_Human_Expert_Analysis_Report, Object_to_Human_Expert_Analysis_Verdict, Analyze_Again, Download_Pcap_File, IsIgnFile){\n\n        my_result = '';\n\n        my_result += '<span data-toggle=\"tooltip\" title=\"Copy URL to Clipboard\" style=\"margin: 2px;\">';\n        my_result += '<a id=\"copyURL\" class=\"tooltips btn btn-white\" class=\"tooltips btn btn-white\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n            my_result += ' data-container=\"body\" data-placement=\"top\" data-original-title=\"Copy URL to Clipboard\" onclick=\"insert_activity_log(\\''+ sha1 +'\\', 9)\">';\n        my_result += '<img src=\"/static/img/valkyrie_action_icons/Copy_To_%20Clipboard_2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n        my_result += '<span style=\"color:#6291C7;display: table;margin-left: 4px;\">Copy URL to<br>Clipboard</span></a></span>';\n\n\n\n        my_result +='<span data-toggle=\"tooltip\" title=\"Download Automatic Analysis Report\" style=\"margin: 2px;\">';\n        if(Export_Results_to_PDF == \"true\" || Export_Results_to_PDF == true){\n            my_result +='<a href=\"/file/export/pdf?sha1='+ sha1 +'\" target=\"_blank\" class=\"tooltips btn btn-white\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-container=\"body\" data-placement=\"top\" data-original-title=\"Download Automatic Analysis Report\">';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/download_copy2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n            my_result +='<span style=\"color:#6291C7; display: table;margin-left: 0px;\">Export Results <br>To PDF</span></a></span>';\n        }else{\n            my_result +='<a href=\"/file/export/pdf?sha1='+ sha1 +'\" target=\"_blank\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-container=\"body\" data-placement=\"top\" data-original-title=\"Download Automatic Analysis Report\">';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/download_copy.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n            my_result +='<span style=\"display: table;margin-left: 0px;\">Export Results <br>To PDF</span></a></span>';\n        }\n\n        my_result +='<span data-toggle=\"tooltip\" title=\"View Virus Total Result\" style=\"margin: 2px;\">';\n        if(View_Virus_Total_Result == \"true\" || View_Virus_Total_Result == true){\n\n            if(sha256 && sha256 != null && sha256 != \"None\" && sha256 != \"\" && sha256 != \"null\")\n            {\n                my_result +='<a href=\"https://www.virustotal.com/en/file/'+ sha256 +'/analysis/\" target=\"_blank\" class=\"tooltips btn btn-white\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                    my_result +=' style=\"padding:0; background-color:#0d92ce;\" data-container=\"body\" data-placement=\"top\"';\n                    my_result +='data-original-title=\"View Virus Total Result\" onclick=\"insert_activity_log(\\''+ sha1 +'\\', 8)\">';\n                my_result +='<img src=\"/static/img/valkyrie_action_icons/vt2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                my_result +='<span style=\"color:#6291C7;display: table;margin-left: 6px;\">View Virus <br>Total Result</span></a></span>';\n            }\n            else\n            {\n                my_result +='<a href=\"https://www.virustotal.com/en/search?query=' + sha1 + '\" target=\"_blank\" class=\"tooltips btn btn-white\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                    my_result +=' style=\"padding:0; background-color:#0d92ce;\" data-container=\"body\" data-placement=\"top\"';\n                    my_result +='data-original-title=\"View Virus Total Result\" onclick=\"insert_activity_log(\\''+ sha1 +'\\', 8)\">';\n                my_result +='<img src=\"/static/img/valkyrie_action_icons/vt2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                my_result +='<span style=\"color:#6291C7;display: table;margin-left: 6px;\">View Virus <br>Total Result</span></a></span>';\n\n            }\n        }else{\n\n                my_result +='<a href=\"https://www.virustotal.com/en/file/'+ sha256 +'/analysis/\" target=\"_blank\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                    my_result +=' style=\"padding:0; background-color:#0d92ce;\" data-container=\"body\" data-placement=\"top\"';\n                    my_result +='data-original-title=\"View Virus Total Result\" onclick=\"insert_activity_log(\\''+ sha1 +'\\', 8)\">';\n                my_result +='<img src=\"/static/img/valkyrie_action_icons/vt.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                my_result +='<span style=\"display: table;margin-left: 6px;\">View Virus <br>Total Result</span></a></span>';\n\n        }\n\n        if (!IsIgnFile) {\n            if (Kill_chain_ready == \"true\" || Kill_chain_ready == true) {\n                my_result += '<span data-toggle=\"tooltip\" title=\"Kill Chain Report\" style=\"margin: 2px;\">';\n                my_result += '<a href=\"/kill/chain/' + sha1 + '/summary\" class=\"tooltips btn btn-white\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\" data-container=\"body\"';\n                my_result += ' data-placement=\"top\" data-original-title=\"Kill Chain Report\">';\n                my_result += '<img src=\"/static/img/valkyrie_action_icons/file_text_data_copy2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                my_result += '<span style=\"color:#6291C7;display: table;margin-left: 12px;\">Kill Chain <br>Report</span></a></span>';\n\n            } else if (Kill_Chain_report_is_being_created == \"true\" || Kill_Chain_report_is_being_created == true) {\n                my_result += '<span data-toggle=\"tooltip\" title=\"Kill Chain report is being created\" style=\"margin: 2px;\">';\n                my_result += '<a onclick=\"return false;\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\" data-container=\"body\"';\n                my_result += ' data-placement=\"top\" data-original-title=\"Kill Chain report is being created\">';\n                my_result += '<img src=\"/static/img/valkyrie_action_icons/Kill_Chain_in_Progress_2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                my_result += '<span style=\"color:#6291C7;display: table;margin-left: 2px;\">Kill Chain <br>Report is<br>Being Created</span></a></span>';\n\n            } else if (Send_to_Kill_Chain_Analysis == \"true\" || Send_to_Kill_Chain_Analysis == true) {\n                my_result += '<span data-toggle=\"tooltip\" title=\"Send to Kill Chain Report\" style=\"margin: 2px;\">';\n                my_result += '<a href=\"#killchainModal\" class=\"tooltips btn btn-white\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\" data-container=\"body\"';\n                my_result += ' data-placement=\"top\" data-toggle=\"modal\" data-original-title=\"Send to Kill Chain Report\">';\n                my_result += '<img src=\"/static/img/valkyrie_action_icons/Send_To_Kill_Chain_Analysis_2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                my_result += '<span style=\"color:#6291C7;display: table;margin-left: 12px;\">Send to<br>Kill Chain <br>Report</span></a></span>';\n            } else {\n                my_result += '<span data-toggle=\"tooltip\" title=\"Kill Chain Report\" style=\"margin: 2px;\">';\n                my_result += '<a href=\"/kill/chain/' + sha1 + '/summary\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\" data-container=\"body\"';\n                my_result += ' data-placement=\"top\" data-original-title=\"Kill Chain Report\">';\n                my_result += '<img src=\"/static/img/valkyrie_action_icons/file_text_data_copy.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                my_result += '<span style=\"display: table;margin-left: 12px;\">Kill Chain <br>Report</span></a></span>';\n            }\n\n\n\n            if(Send_to_Human_Expert_Analysis == \"true\" || Send_to_Human_Expert_Analysis == true){\n                my_result +='<span data-toggle=\"tooltip\" title=\"Send to Human Expert Analysis\" style=\"margin: 2px;\">';\n                my_result +='<form method=\"post\" action=\"/submit/manual/analysis/'+ sha1 +'\" style=\"display: inline;\" onsubmit=\"return confirmManualSubmit(\\'' + sha1 + '\\')\">';\n                my_result +='<button type=\"submit\" class=\"tooltips btn btn-white\" style=\"padding-left: 10px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-container=\"body\" data-placement=\"top\" data-original-title=\"Send to Human Expert Analysis\">';\n                my_result +='<img src=\"/static/img/valkyrie_action_icons/Shape_Copy2.png\" style=\"height: 25px;margin-right: 26px;margin-left: 30px;width: 25px;\"/>';\n                my_result +='<span style=\"color:#6291C7;display: table;margin-left: 0px;\">Send To <br> Human Expert <br> Analyst</span></a></span>';\n                my_result +='</button>';\n                my_result +='</form></span>';\n            }else{\n                if(Human_Expert_Is_In_Progress == \"true\" || Human_Expert_Is_In_Progress == true){\n                    my_result +='<span data-toggle=\"tooltip\" title=\"Human Expert Analysis Is In Progress\" style=\"margin: 2px;\">';\n                    my_result +='<a onclick=\"sendToManual(\\'' + sha1 + '\\')\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                    my_result +=' data-container=\"body\" data-placement=\"top\" data-original-title=\"Human Expert Analysis Is In Progress\">';\n                    my_result +='<img src=\"/static/img/valkyrie_action_icons/Kill_Chain_in_Progress_2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                    my_result +='<span style=\"color:#6291C7; display: table;margin-left: 0px;\">Human Expert <br> Analysis <br> Is In Progress </span></a></span>';\n                }\n                else{\n                    my_result +='<span data-toggle=\"tooltip\" title=\"Send to Human Expert Analysis\" style=\"margin: 2px;\">';\n                    my_result +='<a onclick=\"sendToManual(\\'' + sha1 + '\\')\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                    my_result +=' data-container=\"body\" data-placement=\"top\" data-original-title=\"Send to Human Expert Analysis\">';\n                    my_result +='<img src=\"/static/img/valkyrie_action_icons/Shape_Copy.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n                    my_result +='<span style=\"display: table;margin-left: 0px;\">Send To <br> Human Expert <br> Analyst</span></a></span>';\n                }\n            }\n        }\n\n        if(Object_to_Human_Expert_Analysis_Verdict == \"true\" || Object_to_Human_Expert_Analysis_Verdict == true){\n            my_result +='<span data-toggle=\"tooltip\" title=\"Object to Human Expert Analysis Verdict\" style=\"margin: 2px;\">';\n            my_result +='<a id=\"objectToggle\" class=\"tooltips btn btn-white\" style=\"padding: 6px 8px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-toggle=\"modal\" data-container=\"body\" data-placement=\"top\" data-original-title=\"Object to Human Expert Analysis Verdict\" href=\"#objectModal\">';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/Object_To_Human_Analyst_2.png\" style=\"height: 25px;margin-right: 32px;margin-left: 32px;width: 25px;\"/>';\n            my_result +='<span style=\"color:#6291C7;display: table;margin-left: 0px;\">Object to <br>Human Expert <br>Analysis Verdict</span></a></span>';\n        }else{\n            my_result +='<span data-toggle=\"tooltip\" title=\"Object to Human Expert Analysis Verdict\" style=\"margin: 2px;\">';\n            my_result +='<a id=\"objectToggle\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 8px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-toggle=\"modal\" data-container=\"body\" data-placement=\"top\" data-original-title=\"Object to Human Expert Analysis Verdict\" href=\"#objectModal\">';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/Object_To_Human_Analyst.png\" style=\"height: 25px;margin-right: 32px;margin-left: 32px;width: 25px;\"/>';\n            my_result +='<span style=\"display: table;margin-left: 0px;\">Object to <br>Human Expert <br>Analysis Verdict</span></a></span>';\n        }\n\n        //download_human_expert_analysis\n        if(Download_Human_Expert_Analysis_Report == \"true\" || Download_Human_Expert_Analysis_Report == true){\n            my_result +='<span data-toggle=\"tooltip\" title=\"Download Human Expert Analysis Report\" style=\"margin: 2px;\">';\n            my_result +='<form method=\"post\" action=\"/manual/analysis/'+ sha1 +'/report/\" style=\"display: inline;\">';\n            my_result +='<button type=\"submit\" class=\"tooltips btn btn-white\" style=\"padding-left: 10px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-container=\"body\" data-placement=\"top\" data-original-title=\"Download Human Expert Analysis Report\">';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/Download_Manua_Analysis_Report_2.png\" style=\"height: 25px;margin-right: 26px;margin-left: 30px;width: 25px;\"/>';\n            my_result +='<span style=\"color:#6291C7;display: table;margin-left: 0px;\">Download <br>Human Expert <br>Analysis Report</span></a></span>';\n            my_result +='</button>';\n            my_result +='</form></span>';\n        }else{\n            my_result +='<span data-toggle=\"tooltip\" title=\"Download Human Expert Analysis Report\" style=\"margin: 2px;\">';\n            my_result +='<form method=\"post\" action=\"/manual/analysis/'+ sha1 +'/report/\" style=\"display: inline;\">';\n            my_result +='<button type=\"submit\" class=\"disabled tooltips btn btn-white\" style=\"padding-left: 10px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-container=\"body\" data-placement=\"top\" data-original-title=\"Download Human Expert Analysis Report\">';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/Download_Manua_Analysis_Report.png\" style=\"height: 25px;margin-right: 26px;margin-left: 30px;width: 25px;\"/>';\n            my_result +='<span style=\"display: table;margin-left: 0px;\">Download <br>Human Expert <br>Analysis Report</span></a></span>';\n            my_result +='</button>';\n            my_result +='</form></span>';\n        }\n\n        if(Download_Pcap_File == \"true\" || Download_Pcap_File == true){\n            my_result +='<span data-toggle=\"tooltip\" title=\"Download Pcap File\" style=\"margin: 2px;\">';\n            my_result +='<a id=\"downloadPcapFile\" class=\"tooltips btn btn-white\" style=\"text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-toggle=\"modal\" data-container=\"body\" data-placement=\"top\" data-original-title=\"Download Pcap File\" ';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/Download_Manua_Analysis_Report_2.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n            my_result +='<span style=\"color:#6291C7;display: table;margin-left: 11px;\">Download <br>Pcap File</span></a></span>';\n        }else{\n\n        }\n\n\n        if(Analyze_Again == \"true\" || Analyze_Again == true){\n            my_result +='<span data-toggle=\"tooltip\" title=\"Reanalyze\" style=\"margin: 2px;\">';\n            my_result +='<a id=\"analyze_again\" class=\"tooltips btn btn-white\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n                my_result +=' data-toggle=\"modal\" data-container=\"body\" data-placement=\"top\" data-original-title=\"Reanalyze\" href=\"/fvs_again?sha1=9b4688ba4788e34bce47d91b0accc98d33dbf8d2\" onclick=\"showLoader(\\'ReAnalyzing...\\')\">';\n            my_result +='<img src=\"/static/img/valkyrie_action_icons/Reanalyze_File_2.png\" style=\"height: 25px;margin-top: 5px;margin-left: 25px;\"/>';\n            my_result +='<span style=\"color:#6291C7;display: table;\">Reanalyze</span></a></span>';\n        }else{\n            // my_result +='<span data-toggle=\"tooltip\" title=\"Reanalyze\" style=\"margin: 2px;\">';\n            // my_result +='<a id=\"analyze_again\" class=\"tooltips btn btn-white disabled\" style=\"padding: 6px 12px;text-transform: capitalize;display: inline-grid;width: 110px;height: 90px;color: #c8ccce;vertical-align: text-bottom;\"';\n            //     my_result +=' data-toggle=\"modal\" data-container=\"body\" data-placement=\"top\" data-original-title=\"Analyze Again\">';\n            // my_result +='<img src=\"/static/img/valkyrie_action_icons/Reanalyze_File.png\" style=\"height: 25px;margin-right: 28px;margin-left: 28px;width: 25px;\"/>';\n            // my_result +='<span style=\"display: table;margin-left: 18px;\">Reanalyze</span></a></span>';\n        }\n\n\n        my_result += '</div>';\n        $('.table-action-menu').html(my_result);\n\n    }\n    jQuery(document).ready(function() {\n\n        $(\"#page-content-div\").addClass(\"container-fluid\");\n        $(\"#page-content-div\").removeClass(\"container\");\n\n        table_action_menu_function(file_info_sha256,false, false, false, false, false,\n                false, false, false, false, false, false, ign_file);\n        \n        var copyBtn = document.querySelector('#copyURL');\n        copyBtn.addEventListener('click', function(event) {\n          copyTextToClipboard();\n        });\n        \n        toastr.options = {\n                \"closeButton\" : true,\n                \"debug\" : false,\n                \"positionClass\" : \"toast-top-right\",\n                \"onclick\" : null,\n                \"showDuration\" : \"1500\",\n                \"hideDuration\" : \"500\",\n                \"timeOut\" : \"4000\",\n                \"extendedTimeOut\" : \"1000\",\n                \"showEasing\" : \"swing\",\n                \"hideEasing\" : \"linear\",\n                \"showMethod\" : \"fadeIn\",\n                \"hideMethod\" : \"fadeOut\"\n            }\n\n\n\n        $(\"body\").addClass(\"page-md page-header-menu-fixed\");\n        // jQuery(\"time.timeago\").timeago();\n        $(\"#uploadFileToggle\").attr(\"data-toggle\",\"modal\");\n\n        \n\n        \n\n        \n\n\n\n        \n\n        $(\".url-decode\").each(function(){\n            try {\n                $(this).text(decodeURIComponent($(this).text()));\n                }\n            catch(err) {}\n        });\n\n        hideLoader();\n\n        \n\n        \n\n    });\n\n    (function timeAgo(selector) {\n\n        var templates = {\n            prefix: \"\",\n            suffix: \" ago\",\n            minutes: \"%d minute(s)\",\n            hours: \"%d hour(s)\",\n            days: \"%d day(s)\",\n            months: \"%d month(s)\",\n            years: \"%d year(s)\"\n        };\n        var template = function (t, n) {\n            if( Math.abs(Math.floor(n)) > 0)\n                return templates[t] && templates[t].replace(/%d/i, Math.abs(Math.floor(n)));\n            else\n                return \"\";\n        };\n\n        var timer = function (time) {\n            if (!time) return;\n\n            time = convertToLocalDatetime(time);\n\n            var now = new Date();\n            var seconds = ((now.getTime() - time) * .001) >> 0;\n            var minutes = seconds / 60;\n            seconds = seconds / 60;\n            var hours = minutes / 60;\n            minutes = minutes % 60;\n            var days = hours / 24;\n            hours = hours % 24;\n            var months = days / 30;\n            days = days % 30;\n            var years = months / 12;\n            months = months % 12;\n\n            if(months > 1) {\n                return templates.prefix + ((years > 0)? template(\"years\", years) + \" \": \"\") + ((months > 0)? template(\"months\", months) + \" \": \"\") + ((days > 0)? template(\"days\", days) + \" \": \"\") + templates.suffix;\n            }\n            else if( minutes < 1 ) {\n                return \"Just Now\";\n            }\n            else {\n                return templates.prefix + ((days > 0)? template(\"days\", days) + \" \": \"\") + ((hours > 0)? template(\"hours\", hours) + \" \": \"\") + ((minutes > 0)? template(\"minutes\", minutes) + \" \": \"\") + templates.suffix;\n            }\n        };\n\n        var elements = document.getElementsByClassName('timeago');\n        for (var i in elements) {\n            var $this = elements[i];\n            if (typeof $this === 'object') {\n                $this.innerHTML = timer($this.getAttribute('title') || $this.getAttribute('datetime'));\n            }\n        }\n\n    })();\n\n\n\n    function objectManualSubmit(sha1)\n    {\n           if (confirm('Are you sure you want to object human expert analysis verdict?'))\n           {\n              $(\"#form_\"+sha1+\"_object_to_manual_analysis\").removeAttr(\"onsubmit\");\n              $(\"#form_\"+sha1+\"_object_to_manual_analysis\").submit();\n              showLoader(\"Human Expert Analysis verdict will be re-evaluated\")\n           }\n        return false;\n    }\n\n\n    function confirmKillChainSubmit(sha1, trigger_kill_chain)\n    {\n        debugger;\n        if (confirm('Are you sure you want to send this file to kill chain analysis?'))\n           {\n              if (trigger_kill_chain)\n              {\n                  $(\"#form_\"+sha1+\"_kill_chain_submit\").removeAttr(\"onsubmit\");\n                  $(\"#form_\"+sha1+\"_kill_chain_submit\").submit();\n                  showLoader(\"Sending to Kill-Chain Analysis...\")\n              }\n              else\n              {\n                  $(\"#form_\"+sha1+\"_kill_chain_submit\").removeAttr(\"onsubmit\");\n                  $(\"#form_\"+sha1+\"_kill_chain_submit\").remove()\n                  table_action_menu_function(sha256,sha1, Export_Results_to_PDF, View_Virus_Total_Result, false, true,\n                        false, Send_to_Human_Expert_Analysis, Download_Human_Expert_Analysis_Report, Object_to_Human_Expert_Analysis_Verdict, Analyze_Again, Download_Pcap_File, ign_file);\n                \n                var copyBtn = document.querySelector('#copyURL');\n                copyBtn.addEventListener('click', function(event) {\n                  copyTextToClipboard();\n                });\n                \n                  alert('Kill-Chain report is being created');\n              }\n           }\n        return false;\n    }\n\n\n    function handleFinalScore(verdict, verdict_source)\n    {\n\n        var malwareIcon = '<img src=\"/static/img/file_info/valkyrie_malware_icon_large.png\" style=\"width: 130px; height: 130px; margin-bottom: 10px !important;\" class=\"logo-default\">';\n        var malwareText = '<span class=\"uppercase bold\">Malware</span>';\n\n        var undetectedIcon = '<img src=\"/static/img/file_info/valkyrie_no_treat_icon_large.png\" style=\"width: 130px; height: 130px; margin-bottom: 10px !important;\" class=\"logo-default\">';\n        var undetectedText = '<span class=\"uppercase bold\">No Threat Found</span>';\n\n        if(ign_file)\n            undetectedText = '<span class=\"uppercase bold\">Explicit Unknown</span>';\n\n        var cleanIcon = '<img src=\"/static/img/file_info/valkyrie_clean_icon_large.png\" style=\"width: 130px; height: 130px; margin-bottom: 10px !important;\" class=\"logo-default\">';\n        var cleanText = '<span class=\"uppercase bold\">Clean</span>';\n\n        var PUAIcon = '<img src=\"/static/img/file_info/valkyrie_malware_icon_large.png\" style=\"width: 130px; height: 130px; margin-bottom: 10px !important;\" class=\"logo-default\">';\n        var PUAText = '<span class=\"uppercase bold\">PUA</span>';\n\n        var sourceText = '<h5 style=\"margin-top: 0px;\">Valkyrie Final Verdict</h5>';\n        var undetectedEmptyText = '<h5 style=\"margin-top: 0px;\"></h5>';\n\n        if(verdict == 1)\n        {\n            $(\"#final-score-icon\").html(malwareIcon);\n            $(\"#final-score-text\").html(malwareText);\n\n            //if([\"Valkyrie Human Expert Analysis Overall Verdict\", \"Signature Based Detection\", \"CAV Signature Based\"].indexOf(verdict_source) < 0)\n            //{\n                //$(\"#killchainli\").hide();\n            //}\n        }\n        else if (verdict == -1)\n        {\n            $(\"#final-score-icon\").html(cleanIcon);\n            $(\"#final-score-text\").html(cleanText);\n            //$(\"#killchainli\").hide();\n        }\n        else if (verdict == 3)\n        {\n            $(\"#final-score-icon\").html(PUAIcon);\n            $(\"#final-score-text\").html(PUAText);\n            //$(\"#killchainli\").hide();\n        }\n        else\n        {\n            $(\"#final-score-icon\").html(undetectedIcon);\n            $(\"#final-score-text\").html(undetectedText);\n            //$(\"#killchainli\").hide();\n        }\n\n\n        if(verdict != 0) {\n            $(\"#final-score-text-source\").html(sourceText);\n        }\n        else {\n            $(\"#final-score-text-source\").html(undetectedEmptyText);\n        }\n        $(\"#final-score\").addClass(\"tada animated\");\n        $(\"#file-summary-div\").append(\"<h5 class='bounceInLeft animated'><strong>Verdict Source: &nbsp</strong>\" + verdict_source + \"</h5>\");\n\n        table_action_menu_function(file_info_sha256,file_info_sha1, Export_Results_to_PDF, View_Virus_Total_Result, Send_to_Kill_Chain_Analysis, Kill_Chain_report_is_being_created,\n            Kill_chain_ready, Send_to_Human_Expert_Analysis, Download_Human_Expert_Analysis_Report, Object_to_Human_Expert_Analysis_Verdict, Analyze_Again, Download_Pcap_File, ign_file);\n        \n        var copyBtn = document.querySelector('#copyURL');\n        copyBtn.addEventListener('click', function(event) {\n          copyTextToClipboard();\n        });\n        \n    }\n\n    function handleCertificateResult(certificate_validation, vendor_array, show_popup)\n    {\n        var validCert = 0\n        var validVendor = 0\n\n        \n            var n = convertToLocalDateByDate(new Date());\n        \n\n        var cert_valid = '<tr id=\"cert_row\" class=\"clean\"><td>File Certificate Validation</td><td class=\"to-local-date\">' + n + '</td><td>Certificate and Vendor name are Valid</td><td class=\"fit\"><i class=\"fa fa-check-circle fl-24 font-green-clean\"></i></td></tr>';\n        var cert_valid_vendor_notvalid = '<tr id=\"cert_row\" class=\"certificate\"><td>File Certificate Validation</td><td class=\"to-local-date\">' + n + '</td><td>Vendor not found in Trusted List</td><td class=\"fit\"><i class=\"fa fa-question-circle fl-24 font-yellow-lemon\"></i></td></tr>';\n        var cert_notvalid_vendor_valid = '<tr id=\"cert_row\" class=\"certificate\"><td>File Certificate Validation</td><td class=\"to-local-date\">' + n + '</td><td>Certificate Not Valid,Vendor name Valid</td><td class=\"fit\"><i class=\"fa fa-question-circle fl-24 font-yellow-lemon\"></i></td></tr>';\n        var cert_not_valid = '<tr id=\"cert_row\" class=\"certificate\"><td>File Certificate Validation</td><td class=\"to-local-date\">' + n + '</td><td>Certificate and Vendor name are Not Valid</td><td class=\"fit\"><i class=\"fa fa-question-circle fl-24 font-yellow-lemon\"></i></td></tr>';\n        var cert_gray_listed = '<tr id=\"cert_row\" class=\"pua\"><td>File Certificate Validation</td><td class=\"to-local-date\">' + n + '</td><td>Vendor is Gray Listed</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-yellow-casablanca\"></i></td></tr>';\n        var cert_not_applicable = '<tr id=\"cert_row\" ><td>File Certificate Validation</td><td class=\"to-local-date\">' + n + '</td><td>Not Applicable</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\">help</i></td></tr>';\n\n        if (vendor_array != \"\" && vendor_array != null)\n            {\n                if (vendor_array[0].Valid)\n                {\n                    $(\"#vendor_validation_toggle\").append('&nbsp-&nbsp Verified &nbsp<i class=\"fa fa-check font-green md-18\"></i>')\n                    validVendor=1\n                }\n                else if (vendor_array.length > 1 && vendor_array[1].status == 'Gray Listed'){\n                    $(\"#vendor_validation_toggle\").append('&nbsp-&nbsp Gray Listed &nbsp<i class=\"fa fa-exclamation-circle font-yellow-casablanca md-18\"></i>')\n                    validVendor=0\n                }\n                else\n                {\n                    $(\"#vendor_validation_toggle\").append('&nbsp-&nbsp Not Verified &nbsp<i class=\"fa fa-close font-red md-18\"></i>')\n                }\n                $.each(vendor_array, function( index, value ) {\n                        if(index != 0)\n                        {\n                            var vendorTemplate = '<a data-toggle=\"collapse\" href=\"#vendor_validation_item_'+index+'\" aria-expanded=\"true\" style=\"width:100%\"><h5><strong>[+] ' + value.vendor_name + '</strong></h5></a>';\n                            vendorTemplate += '<div id=\"vendor_validation_item_'+index+'\" class=\"table-scrollable table-scrollable-borderless collapse in\" aria-expanded=\"true\">';\n                            vendorTemplate += '<table class=\"table table-bordered table-hover\"><tbody>';\n\n                            if (value.verified)\n                            {\n                                vendorTemplate += '<tr><td>Status</td><td>Valid &nbsp<i class=\"fa fa-check font-green\"></i></td></tr>';\n                            }\n                            else\n                            {\n                                vendorTemplate += '<tr><td>Status</td><td>Not Valid &nbsp<i class=\"fa fa-close font-red\"></i></td></tr>';\n                            }\n\n                            vendorTemplate +='</tbody></table></div>';\n                            $(\"#vendor_validation\").append(vendorTemplate);\n                        }\n                    });\n\n            }\n            else\n            {\n                $(\"#vendor_validation_toggle\").append('&nbsp-&nbsp Vendor Validation is not Applicable &nbsp<i class=\"fa fa-question font-yellow md-18\"></i>')\n            }\n\n\n            //Update file_details if validation exists\n            if (certificate_validation != \"\" && certificate_validation != null)\n            {\n                <!--debugger;-->\n                if (certificate_validation[0].Status =='Success')\n                {\n                    $(\"#cert_validation_toggle\").append('&nbsp-&nbsp' + certificate_validation[0].Status + '&nbsp<i class=\"fa fa-check font-green md-18\"></i>')\n                    validCert=1\n                }\n                else if (certificate_validation[0].Valid)\n                {\n                    $(\"#cert_validation_toggle\").append('&nbsp-&nbsp Verified &nbsp<i class=\"fa fa-check font-green md-18\"></i>')\n                    validCert=1\n                }\n                else if (certificate_validation[0].Status !='Success')\n                {\n                    $(\"#cert_validation_toggle\").append('&nbsp-&nbsp' + certificate_validation[0].Status + '&nbsp<i class=\"fa fa-close font-red md-18\"></i>')\n                }\n\n\n                $.each(certificate_validation, function( index, value ) {\n                        if(index != 0)\n                        {\n                            var cerTemplate = '<a data-toggle=\"collapse\" href=\"#cert_validation_item_'+index+'\" aria-expanded=\"true\" style=\"width:100%\"><h5><strong>[+] ' + value.subject_cn + '</strong></h5></a>';\n                            cerTemplate += '<div id=\"cert_validation_item_'+index+'\" class=\"table-scrollable table-scrollable-borderless collapse in\" aria-expanded=\"true\">';\n                            cerTemplate += '<table class=\"table table-bordered table-hover\"><tbody>';\n\n                            if (value.status_code =='NoError')\n                            {\n                                cerTemplate += '<tr><td>Status</td><td>' + value.status_code + ' &nbsp<i class=\"fa fa-check font-green\"></i></td></tr>';\n                            }\n                            else if(certificate_validation[0].Status =='Success' && (value.status_code =='NotTimeValid' || value.status_code =='CtlNotTimeValid' || value.status_code =='ExplicitDistrust' || value.status_code =='HasNotDefinedNameConstraint'\n                            || value.status_code =='HasNotPermittedNameConstraint' || value.status_code =='HasNotSupportedCriticalExtension' || value.status_code =='HasNotSupportedNameConstraint' || value.status_code =='HasWeakSignature'\n                            || value.status_code =='NoIssuanceChainPolicy' || value.status_code =='NotTimeNested') )\n                            {\n                                cerTemplate += '<tr><td>Status</td><td>' + value.status_code +  ' &nbsp<i class=\"fa fa-bolt font-yellow-casablanca\"></i>'+' (no effect on chain status) ' + '</td></tr>';\n                            }\n                            else if(value.status==0) // for old data result\n                            {\n                               cerTemplate += '<tr><td>Status</td><td>Valid &nbsp<i class=\"fa fa-check font-green\"></i></td></tr>';\n                            }\n                            else\n                            {\n                               cerTemplate += '<tr><td>Status</td><td> ' +  value.status_code + ' &nbsp<i class=\"fa fa-close font-red\"></i></td></tr>';\n                            }\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Start Date</td><td>' + value.startdate + '</td></tr>';\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> End Date</td><td>' + value.enddate + '</td></tr>';\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Sha256</td><td>' + value.sha256 + '</td></tr>';\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Serial </td><td>' + value.serial_number + '</td></tr>';\n\n                            if (value.subject_cn != null && value.subject_cn != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Subject Name </td><td>' + value.subject_cn + '</td></tr>';\n                            }\n\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Subject Key Identifier </td><td>' + value.subject_key_identifier + '</td></tr>';\n\n                            if (value.subject_o != null && value.subject_o != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Subject Organization </td><td>' + value.subject_o + '</td></tr>';\n                            }\n                            if (value.subject_l != null && value.subject_l != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Subject Locality </td><td>' + value.subject_l + '</td></tr>';\n                            }\n                            if (value.subject_s != null && value.subject_s != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Subject State </td><td>' + value.subject_s + '</td></tr>';\n                            }\n                            if (value.subject_c != null && value.subject_c != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Subject Country </td><td>' + value.subject_c + '</td></tr>';\n                            }\n                            if (value.subject_ou != null && value.subject_ou != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Subject Organizational Unit </td><td>' + value.subject_ou + '</td></tr>';\n                            }\n\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Issuer Name </td><td>' + value.issuer_cn + '</td></tr>';\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Issuer Key Identifier </td><td>' + value.authority_key_identifier + '</td></tr>';\n\n                            if (value.issuer_o != null && value.issuer_o != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Issuer Organization </td><td>' + value.issuer_o + '</td></tr>';\n                            }\n                            if (value.issuer_l != null && value.issuer_l != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Issuer Locality </td><td>' + value.issuer_l + '</td></tr>';\n                            }\n                            if (value.issuer_s != null && value.issuer_s != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Issuer State </td><td>' + value.issuer_s + '</td></tr>';\n                            }\n                            if (value.issuer_c != null && value.issuer_c != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Issuer Country </td><td>' + value.issuer_c + '</td></tr>';\n                            }\n                            if (value.issuer_ou != null && value.issuer_ou != \"\")\n                            {\n                                cerTemplate += '<tr><td class=\"fit no-wrap\"> Issuer Organizational Unit </td><td>' + value.issuer_ou + '</td></tr>';\n                            }\n\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Crl link </td><td>' + value.crl + '</td></tr>';\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Key Usage </td><td>' + value.key_usage + '</td></tr>';\n                            cerTemplate += '<tr><td class=\"fit no-wrap\"> Extended Usage </td><td>' + value.enhanced_key_usage + '</td></tr>';\n\n                            cerTemplate +='</tbody></table></div>';\n                            $(\"#cert_validation\").append(cerTemplate);\n                        }\n                    });\n\n\n                if (validCert==1 && validVendor==1)\n                {\n                    $('#summary-table-body').append(cert_valid);\n                    if(show_popup)\n                        toastr.success(\"Certificate and Vendor name are Valid\", \"Certificate Validation\");\n                }\n                else if(validCert==0 && validVendor ==0 && vendor_array.length > 1 && vendor_array[1].status == 'Gray Listed')\n                {\n                    $('#summary-table-body').append(cert_gray_listed);\n                    if(show_popup)\n                        toastr.warning(\"Vendor is Gray Listed\", \"Certificate Validation\");\n                }\n                else if(validCert==1 && validVendor ==0)\n                {\n                    if(vendor_array.length > 1 && vendor_array[1].status == 'Gray Listed')\n                    {\n                        $('#summary-table-body').append(cert_gray_listed);\n                    if(show_popup)\n                        toastr.warning(\"Vendor is Gray Listed\", \"Certificate Validation\");\n                    }\n                    else{\n                        $('#summary-table-body').append(cert_valid_vendor_notvalid);\n                        if(show_popup)\n                            toastr.info(\"Vendor not found in Trusted List\", \"Certificate Validation\");\n                    }\n                }\n                else if (validCert==0 && validVendor ==1)\n                {\n                   $('#summary-table-body').append(cert_notvalid_vendor_valid);\n                    if(show_popup)\n                        toastr.info(\"Certificate Not Valid, Vendor name Valid\", \"Certificate Validation\");\n                }\n                else\n                {\n                   $('#summary-table-body').append(cert_not_valid);\n                    if(show_popup)\n                        toastr.warning(\"Certificate and Vendor name are Not Valid\", \"Certificate Validation\");\n                }\n\n\n            }\n            else\n            {\n                $(\"#cert_validation_toggle\").append('&nbsp-&nbsp Certificate Validation is not Applicable &nbsp<i class=\"fa fa-question font-yellow md-18\"></i>')\n                $('#summary-table-body').append(cert_not_applicable);\n                if(show_popup)\n                    toastr.info(\"Not Applicable\", \"Certificate Validation\");\n            }\n    }\n\n\n    function initTreeView() {\n        $('#importTreeview').jstree({\n                \"core\" : {\n                    \"themes\" : {\n                        \"responsive\": false,\n                        \"dots\": false\n                    }\n                },\n                \"types\" : {\n                    \"default\" : {\n                        \"icon\" : \"fa fa-cubes icon-state-success icon-lg\"\n                    },\n                    \"file\" : {\n                        \"icon\" : \"fa fa-cube icon-state-info icon-lg\"\n                    }\n                },\n                \"plugins\": [\"types\"]\n            });\n    }\n\n    function handleContentHeight()\n    {\n        checkContentHeight();\n\n        \n    }\n\n    function handleFileDetailsResult(data)\n    {\n        if(data != null && data != {} && data != []){\n            if (data.hasOwnProperty(\"magic_literal\"))\n            {\n                magic_literal_html = \"<h5><strong>File Type: &nbsp</strong>\" + data.magic_literal + \"</h5>\";\n                $(\"#filename_h5\").after(magic_literal_html);\n            }\n\n            // PE HEADERS TABLE\n            pe_headers_html = \"\";\n            $(\"#pe_headers_tbody\").html(\"\")\n\n            $.each(data, function(key, val) {\n                if(key != 'sections' && key != 'imports' && key != 'exports' && key != 'resources' && key != 'human_readable_strings'){\n                    if(key == 'meta_data'){\n                        $.each(data.meta_data, function(i, obj) {\n                            $.each(obj, function(sub_val, sub_key) {\n                                pe_headers_html += String.format('<tr><td class=\"text-capitalize\">{0}</td><td>{1}</td></tr>', sub_val.replace(/([A-Z])/g, ' $1').trim(), sub_key);\n                            });\n                        });\n                    }\n                    else if(key != 'magic_literal'){\n                        pe_headers_html += String.format('<tr><td class=\"text-capitalize\">{0}</td><td>{1}</td></tr>', key.replace(new RegExp('_', 'g'), \" \"), val);\n                    }\n                }\n            });\n\n            $(\"#pe_headers_tbody\").html(pe_headers_html);\n\n            // PE SECTIONS TABLE\n            $(\"#pe_sections_tbody\").html(\"\")\n            pe_sections_html = \"\";\n            if (data.hasOwnProperty(\"sections\"))\n            {\n                $.each(data.sections, function(i, item) {\n                    type = \"\";\n                    md5 = \"-\"\n                    if(item[4].indexOf('[SUSPICIOUS]') > 0)\n                        type = \"malware\";\n                    if(item.length > 5)\n                    {\n                        if(item[5].indexOf('[SUSPICIOUS]') > 0)\n                            type = \"malware\";\n                        md5 = item[5];\n                    }\n                    if(item.length > 6)\n                    {\n                        if(item[6].indexOf('[SUSPICIOUS]') > 0)\n                            type = \"malware\";\n                    }\n\n                    pe_sections_html += String.format(\"<tr class='{0}'><td>{1}</td><td>{2}</td><td>{3}</td><td>{4}</td><td>{5}</td><td>{6}</td></tr>\", type, item[0], item[1], item[2], item[3], item[4], md5)\n                });\n                $(\"#pe_sections_tbody\").html(pe_sections_html)\n            }\n            else {\n                $(\"#pe-sections-panel\").remove()\n            }\n\n            // PE IMPORTS\n            $(\"#pe-imports\").html(\"\")\n            if (data.hasOwnProperty(\"imports\") && data.exports.length > 0)\n            {\n                pe_imports_html = '<div id=\"importTreeview\"><ul>';\n                $.each(data.imports, function(key, item) {\n                    row_html = \"<li>\" + item.name + \"<ul>\"\n                    $.each(item.imports, function(i, val) {\n                        row_html += '<li data-jstree=\\'{\"type\":\"file\"}\\'>' + val + '</li>'\n                    });\n                    row_html += \"</ul></li>\"\n                    pe_imports_html += row_html\n                });\n\n                pe_imports_html += '</ul></div>'\n                $(\"#pe-imports\").html(pe_imports_html)\n            }\n            else{\n                $(\"#pe-imports-panel\").remove()\n            }\n\n            // PE EXPORTS\n            $(\"#pe-exports\").html(\"\")\n            if (data.hasOwnProperty(\"exports\") && data.exports.length > 0)\n            {\n                pe_exports_html = '<div style=\"padding:25px\">';\n                $.each(data.exports, function(i, item) {\n                    pe_exports_html += '<p style=\"padding-bottom: 15px;padding-left: 20px;\"><i class=\"fa fa-cube icon-state-info\"></i> ' + item + '</p>'\n                });\n\n                pe_exports_html += '</div>'\n                $(\"#pe-exports\").html(pe_exports_html)\n            }\n            else{\n                $(\"#pe-exports-panel\").remove()\n            }\n\n            // PE RESOURCES\n            $(\"#pe-resources\").html(\"\")\n            if (data.hasOwnProperty(\"resources\") && data.exports.length > 0)\n            {\n                pe_resources_html = '<div style=\"padding:25px\">';\n                $.each(data.resources, function(i, item) {\n                    pe_resources_html += '<p><i class=\"fa fa-file-code-o icon-state-error\"></i> ' + item + '</p>'\n                });\n\n                pe_resources_html += '</div>'\n                $(\"#pe-resources\").html(pe_resources_html)\n            }\n            else{\n                $(\"#pe-resources-panel\").remove()\n            }\n        }\n\n        initTreeView();\n    }\n\n\n</script>\n\n\n<script>\n    var fls_received = false;\n    var static_received = false;\n    var dynamic_received = false;\n    var precise_detectors_received = false;\n    var cav_received = false;\n\n\n    fls_verdict_available = false;\n    jQuery(document).ready(function() {\n        var socket_port = 8087;\n        var options = {\n          'reconnect': true,\n          'reconnection delay': 500,\n          'max reconnection attempts': Infinity\n        }\n\n        \n        var socket = io.connect('http://valkyrie.comodo.com:8087/analysis_result', options);\n        //var socket = io.connect('https://' + document.domain + ':' + socket_port + '/analysis_result', options);\n        socket.emit('join', {room: \"1d7f5680-89e9-4751-a586-a96f2636c2ec\"});\n        \n\n        socket.on('ccs_result', function(data) {\n            if(data.data.return_code != 0)\n            {\n                toastr.error(\"Static Detectors Analysis Failed\", \"Static Detectors Result\");\n                $(\"#valkyrie-info-text\").text(\"Static Detectors Analysis is not Available\")\n            }\n            else\n            {\n                var valkyrieMalwareRowTemplate = '<tr class=\"malware\"><td>{0}</td><td>Suspicious</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-red-thunderbird\"></i></td></tr>';\n                var valkyrieCleanRowTemplate = '<tr class=\"clean\"><td>{0}</td><td>Clean</td><td class=\"fit\"><i class=\"fa fa-check-circle fl-24 font-green-clean\"></i></td></tr>';\n                var valkyrieUnknownRowTemplate = '<tr><td>{0}</td><td>Unknown</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\">help</i></td></tr>';\n                var valkyrieNotAvailableRowTemplate = '<tr><td>{0}</td><td>Clean</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\"></i></td></tr>';\n\n                $(\"#valkyrie-table-body\").html(\"\");\n\n                $.each(data.data.results, function( index, value ) {\n                    if(value != \"\")\n                    {\n                        var rowHtml = \"\";\n                        if(value.result == -2)\n                            rowHtml = String.format(valkyrieNotAvailableRowTemplate, value.detail)\n                        else if(value.result == 1)\n                            rowHtml = String.format(valkyrieCleanRowTemplate, value.detail)\n                        else if(value.result == -1)\n                            rowHtml = String.format(valkyrieMalwareRowTemplate, value.detail)\n                        else\n                            rowHtml = String.format(valkyrieUnknownRowTemplate, value.detail)\n\n                        $(\"#valkyrie-table-body\").append(rowHtml)\n                    }\n                });\n\n                $(\"#valkyrie-info-text\").hide();\n                $(\"#valkyrie-table\").show();\n\n                if(data.data.verdict == 1)\n                    toastr.warning(\"The uploaded file looks like a malicious file\", \"Static Detectors Result\");\n                else\n                    toastr.success(\"Static Detectors Analysis Completed\", \"Static Detectors Result\");\n            }\n\n            $(\"#valkyrie-progress\").hide();\n        });\n\n        socket.on('camas_result', function(data) {\n            dynamic_received = true;\n            if(data.data.return_code != 0)\n            {\n                toastr.error(\"Camas Analysis Not Available\", \"Dynamic Analysis Result\");\n                $(\"#camas-info-text\").text(\"Dynamic Analysis is not Available\")\n                $(\"#bi-info-text\").text(\"Behavioral Information Analysis not Available\")\n\n                $(\"#camas-table-body\").html(\"\");\n                $(\"#camas-final-table-body\").html(\"\");\n\n                var camasNoVerdictRowTemplate = '<tr class=\"\"><td>{0}</td><td class=\"fit\"><i class=\"material-icons font-gray pull-right\">help</i></td></tr>';\n                var camasSummaryTableDataTemplateNoVerdict = '<tr id=\"camas_row\"><td>Dynamic Analysis Overall Verdict</td><td>' + n + '</td><td>Verdict Not Available</td><td class=\"fit\"><i class=\"material-icons font-gray\">help</i></td></tr>';\n\n                var rowHtml = \"\";\n                rowHtml = String.format(camasNoVerdictRowTemplate, \"Verdict Not Available\")\n                $(\"#camas-final-table-body\").append(rowHtml)\n\n                $(\"#camas-final-info-text\").hide();\n                $(\"#camas-res-info-text\").hide();\n                $(\"#camas-final-table\").show();\n\n                /**\n                var summaryRowHtml = \"\";\n                summaryRowHtml = camasSummaryTableDataTemplateNoVerdict;\n\n                if($('#summary-table-body tr').length)\n                    $('#summary-table-body tr:last').before(summaryRowHtml)\n                else\n                    $('#summary-table-body').append(summaryRowHtml)\n                **/\n\n                $(\"#camas-info-text\").hide();\n                $(\"#camas-table\").show();\n            }\n            else\n            {\n                var n = convertToLocalDateByDate(new Date());\n\n                var camasMalwareRowTemplate = '<tr class=\"malware\"><td>{0}</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-red-thunderbird pull-right\"></i></td></tr>';\n                var camasUnknownRowTemplate = '<tr class=\"\"><td>{0}</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon pull-right\">help</i></td></tr>';\n\n                $(\"#camas-table-body\").html(\"\");\n\n                $(\"#camas-final-table-body\").html(\"\");\n\n                var camasSummaryTableDataTemplateUndetected = '<tr id=\"camas_row\"><td>Dynamic Analysis Overall Verdict</td><td>' + n + '</td><td>No Threat Found</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\">help</i></td></tr>';\n                var camasSummaryTableDataTemplateMalware = '<tr id=\"camas_row\" class=\"malware\"><td>Dynamic Analysis Overall Verdict</td><td>' + n + '</td><td>Highly Suspicious</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-red-thunderbird\"></i></td></tr>';\n\n                var rowHtml = \"\";\n                if(data.data.verdict == 1)\n                    rowHtml = String.format(camasMalwareRowTemplate, \"Highly Suspicious\")\n                else\n                    rowHtml = String.format(camasUnknownRowTemplate, \"Threat not detected\")\n\n                $(\"#camas-final-table-body\").append(rowHtml)\n\n                $(\"#camas-final-info-text\").hide();\n                $(\"#camas-final-table\").show();\n\n                var summaryRowHtml = \"\";\n                if(data.data.verdict == 1)\n                    summaryRowHtml = camasSummaryTableDataTemplateMalware;\n                else\n                    summaryRowHtml = camasSummaryTableDataTemplateUndetected;\n\n                if($('#summary-table-body tr').length)\n                    $('#summary-table-body tr:last').before(summaryRowHtml)\n                else\n                    $('#summary-table-body').append(summaryRowHtml)\n\n                $.each(data.data.results, function( index, value ) {\n                    if(value != \"\")\n                    {\n                        var rowHtml = \"\";\n                        if(value == \"Undetected\")\n                        {\n                            rowHtml = String.format(camasUnknownRowTemplate, value);\n                        }\n                        else\n                        {\n                            rowHtml = String.format(camasMalwareRowTemplate, value);\n                        }\n\n                        $(\"#camas-table-body\").append(rowHtml)\n                    }\n                });\n\n                $(\"#camas-info-text\").hide();\n                $(\"#camas-res-info-text\").hide();\n                $(\"#camas-table\").show();\n\n                if(data.data.verdict == 1)\n                    toastr.warning(\"The uploaded file looks like a malicious file\", \"Dynamic Analysis Overall Verdict\");\n                else\n                    toastr.success(\"Dynamic Analysis Completed\", \"Dynamic Analysis Overall Verdict\");\n\n                var biPanelTemplate = '<div class=\"panel panel-default\"><div class=\"panel-heading\"><h4 class=\"panel-title\">'\n                + '<a class=\"accordion-toggle accordion-toggle-styled collapsed\" data-toggle=\"collapse\" href=\"#bi-{0}\" aria-expanded=\"false\">'\n                + '<i class=\"\"></i><strong>{1}</strong></a></h4></div>'\n                + '<div id=\"bi-{2}\" class=\"panel-collapse collapse\" aria-expanded=\"false\">'\n                + '<div style=\"padding:25px\">'\n                + '{3}</div></div></div>';\n\n                var biItemTemplate = '<p><i class=\"\"></i>{0}</p>';\n\n                var biResults = '<h3 id=\"bi-info-text\">Behavioral Information</h3>';\n                if(Object.keys(data.data.groups).length > 0)\n                {\n                    jQuery.each(data.data.groups, function(name, values) {\n                        if(name != \"ipAddresses\" && name != \"urlConnections\")\n                        {\n                            var content = \"\";\n                            for(val in values)\n                                content += String.format(biItemTemplate, values[val]);\n\n                            biResults += String.format(biPanelTemplate, name, name, name, content);\n                        }\n                    });\n                    $('#bi-content-div').html(biResults);\n                }\n                else\n                {\n                    $(\"#bi-info-text\").text(\"Behavioral Information is not Avaliable\")\n                }\n\n                if(data.data.groups.hasOwnProperty(\"ipAddresses\"))\n                {\n                    initializeMap(JSON.parse(data.data.groups.ipAddresses));\n                }\n            }\n\n            $(\"#camas-progress\").hide();\n            $(\"#bi-progress\").hide();\n        });\n\n        socket.on('ml_result', function(data) {\n            static_received = true;\n            if(data.data.return_code != 0)\n            {\n                toastr.error(\"Static Analysis Failed\", \"Static Analysis Overall Verdict\");\n                $(\"#ml-info-text\").text(\"Static Analysis is not Available\")\n            }\n            else\n            {\n                var n = convertToLocalDateByDate(new Date());\n\n                var mlMalwareRowTemplate = '<tr class=\"malware\"><td>Highly Suspicious</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-red-thunderbird\"></i></td></tr>';\n                var mlUnknownRowTemplate = '<tr><td>No Threat Found</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\">help</i></td></tr>';\n\n                var mlSummaryTableDataTemplateUndetected = '<tr><td>Static Analysis Overall Verdict</td><td>' + n + '</td><td>No Threat Found</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\">help</i></td></tr>';\n                var mlSummaryTableDataTemplateMalware = '<tr class=\"malware\"><td>Static Analysis Overall Verdict</td><td>' + n + '</td><td>Highly Suspicious</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-red-thunderbird\"></i></td></tr>';\n\n                $(\"#ml-table-body\").html(\"\");\n\n                var rowHtml = \"\";\n                if(data.data.result == 1)\n                    rowHtml = mlMalwareRowTemplate\n                else\n                    rowHtml = mlUnknownRowTemplate\n\n                $(\"#ml-table-body\").append(rowHtml)\n\n                $(\"#ml-info-text\").hide();\n                $(\"#ml-table\").show();\n\n                var summaryRowHtml = \"\";\n                if(data.data.result == 1)\n                    summaryRowHtml = mlSummaryTableDataTemplateMalware;\n                else\n                    summaryRowHtml = mlSummaryTableDataTemplateUndetected;\n\n                if( $('#camas_row').length )\n                {\n                     // dynamic analysis is exists on summary table\n                    $('#summary-table-body #camas_row').before(summaryRowHtml)\n                }\n                else\n                {\n                    if($('#summary-table-body tr').length)\n                        $('#summary-table-body tr:last').before(summaryRowHtml)\n                    else\n                        $('#summary-table-body').append(summaryRowHtml)\n                    //$(\"#summary-table-body\").append(summaryRowHtml)\n                }\n\n                if(data.data.result == 1)\n                    toastr.warning(\"The uploaded file looks like a malicious file\", \"Static Analysis Overall Verdict\");\n                else\n                    toastr.success(\"Machine Learning Analysis Completed\", \"Static Analysis Overall Verdict\");\n            }\n\n            $(\"#valkyrie-progress\").hide();\n        });\n\n        socket.on('fls_result', function(data) {\n            fls_received = true;\n            if(data.data.return_code != 0)\n            {\n                toastr.error(\"FLS verdict not found\", \"FLS Verdict\");\n            }\n            else\n            {\n                var n = convertToLocalDateByDate(new Date());\n\n                var flsSummaryTableDataTemplateClean = '<tr id=\"fls_row\" class=\"clean\"><td>Signature Based Detection</td><td>' + n + '</td><td>Clean</td><td class=\"fit\"><i class=\"fa fa-check-circle fl-24 font-green-clean\"></i></td></tr>';\n                var flsSummaryTableDataTemplateMalware = '<tr id=\"fls_row\" class=\"malware\"><td>Signature Based Detection</td><td>' + n + '</td><td>Malware</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-red-thunderbird\"></i></td></tr>';\n                var flsSummaryTableDataTemplateMalwareNot = '<tr id=\"fls_row\" ><td>Signature Based Detection</td><td>' + n + '</td><td>No Match</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\">help</i></td></tr>';\n                var flsSummaryTableDataTemplateCleanNot = '<tr id=\"fls_row\" ><td>Blacklist</td><td>' + n + '</td><td>Not in the list</td><td class=\"fit\"><i class=\"material-icons font-yellow-lemon\">help</i></td></tr>';\n                var flsSummaryTableDataTemplatePUA = '<tr id=\"fls_row\" class=\"pua\"><td>Signature Based Detection</td><td>' + n + '</td><td>PUA</td><td class=\"fit\"><i class=\"fa fa-exclamation-circle fl-24 font-yellow-casablanca\"></i></td></tr>';\n\n\n\n                var summaryRowHtml = \"\";\n                if(data.data.verdict == -1)\n                {\n                    summaryRowHtml = flsSummaryTableDataTemplateClean;\n                    fls_verdict_available = true;\n                }\n                else if(data.data.verdict == 1)\n                {\n                    summaryRowHtml = flsSummaryTableDataTemplateMalware;\n                    fls_verdict_available = true;\n                }\n                else if(data.data.verdict == 3)\n                {\n                    summaryRowHtml = flsSummaryTableDataTemplatePUA;\n                    fls_verdict_available = true;\n                }\n                else\n                {\n                    summaryRowHtml = flsSummaryTableDataTemplateMalwareNot;\n                }\n                $(\"#fls_row\").remove();\n                $(\"#summary-table-body\").prepend(summaryRowHtml)\n\n                if(data.data.verdict == 1)\n                    toastr.warning(\"The uploaded file is Blacklisted\", \"FLS Verdict\");\n                else if(data.data.verdict == -1)\n                    toastr.success(\"The uploaded file is Whitelisted\", \"FLS Verdict\");\n                else\n                    toastr.info(\"The uploaded file is not in the list\", \"FLS Verdict\");\n\n            }\n        });\n\n        socket.on('cav_result', function(data) {\n            cav_received = true\n            if(!$('#fls_row').length || ($('#fls_row').length > 0 && !fls_verdict_available))\n            {\n                if(data.data.return_code != 0)\n                {\n                    toastr.error(\"FLS verdict not found\", \"FLS Verdict\");\n                }\n                else\n                {\n                    var n = convertToLocalDate