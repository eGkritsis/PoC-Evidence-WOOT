                                 <span>File Collections</span>\n                                        </a>\n                                    </li>\n                                                            \n                            <li class=\"dropdown resources\">\n                                <a href=\"#\" class=\"dropdown-toggle\" data-toggle=\"dropdown\"><i class=\"fa fa-folder\"></i> <span id=\"choose-resources-dropdown\">Resources</span> <span class=\"caret\"></span></a>\n                                <ul class=\"dropdown-menu\" role=\"menu\">\n                                    <li class=\"\"><a href=\"/release-notes\"><i class=\"fa fa-compass\"></i> Releases & Updates</a></li>                                    <li class=\"faq \"><a href=\"/faq\"><i class=\"glyphicon glyphicon-question-sign\"></i> FAQ</a></li>\n                                    <li class=\"api \"><a href=\"/docs/api/v2\"><i class=\"glyphicon glyphicon-cog\"></i> Public API</a></li>\n                                                                        <li class=\"knowledge-base \">\n                                        <a href=\"/knowledge-base\" target=\"_blank\"><i class=\"glyphicon glyphicon-book\"></i> Knowledge Base</a>\n                                    </li>\n                                    <li role=\"presentation\" class=\"divider\"></li>\n                                    <li class=\"tags \"><a href=\"/tag-cloud\" target=\"_blank\"><i class=\"glyphicon glyphicon-tag\"></i> Tag Cloud</a></li>\n                                                                            <li class=\"tags\"><a href=\"/map\" target=\"_blank\"><i class=\"glyphicon glyphicon-globe\" aria-hidden=\"true\"></i> Threat Map</a></li>\n                                                                    </ul>\n                            </li>\n\n                                                                                                <li class=\"dropdown learn-more\">\n                                        <a href=\"#\" class=\"dropdown-toggle\" data-toggle=\"dropdown\"><i class=\"fa fa-question-circle\"></i> <span id=\"choose-resources-dropdown\">Request Info</span> <span class=\"caret\"></span></a>\n                                        <ul class=\"dropdown-menu\" role=\"menu\">\n                                            <li>\n                                                <a href=\"https://www.crowdstrike.com/endpoint-security-products/falcon-sandbox-malware-analysis/\" target=\"_blank\">\n                                                    <i class=\"fa fa-cloud-upload-alt\"></i>\n                                                    <span>Falcon Sandbox</span>\n                                                </a>\n                                            </li>\n                                            <li>\n                                                <a href=\"https://www.crowdstrike.com/endpoint-security-products/falcon-cyber-threat-search-engine/\" target=\"_blank\">\n                                                    <i class=\"far fa-dot-circle\"></i>\n                                                    <span>Falcon MalQuery</span>\n                                                </a>\n                                            </li>\n                                            <li role=\"presentation\" class=\"divider\"></li>\n                                            <li>\n                                                <a href=\"https://go.crowdstrike.com/HybridAnalysisRequest.html\" target=\"_blank\">\n                                                    <i class=\"fa fa-pencil-alt\"></i>\n                                                    <span>Falcon Sandbox Free Trial</span>\n                                                </a>\n                                            </li>\n                                        </ul>\n                                    </li>\n                                                                                    </ul>\n                        <ul class=\"nav navbar-nav navbar-right\">\n                            <li class=\"dropdown user\">\n                                <a href=\"#\" class=\"dropdown-toggle\" data-toggle=\"dropdown\"><span id=\"dropdown2\">f3bru</span> <span class=\"caret\"></span></a>\n                                <ul class=\"dropdown-menu\" role=\"menu\">\n                                                                                                                <li ><a href=\"/my-submissions/all\">My Submissions</a></li>\n                                                                        <li ><a href=\"/statistics\">Webservice Statistics</a></li>\n                                    <li class=\"\"><a href=\"/advanced-search\">Advanced Search</a></li>\n                                                                            <li class=\"\"><a href=\"/file-collection/search\">File Collection Search</a></li>\n                                                                                                                <li><a href=\"/docs/api/v2#/Feed\" target=\"_blank\">Public Feed</a></li>\n                                                                        <li><a href=\"/report-of-the-day\" target=\"_blank\">Report of the Day</a></li>\n                                                                            <li role=\"presentation\" class=\"divider\"></li>\n                                        <li><a href=\"https://www.crowdstrike.com/endpoint-security-products/falcon-sandbox-malware-analysis/\" target=\"_blank\">Falcon Sandbox Website</a></li>\n                                        <li><a href=\"https://hybrid-analysis.blogspot.de/\" target=\"_blank\">Hybrid Analysis Blog</a></li>\n                                                                                                                                                                                                                                                                    <li >\n                                            <a href=\"/my-account\">\n                                                Profile\n                                                                                            </a>\n                                        </li>\n                                        <li><a href=\"#\" data-url=\"/logout\" class=\"trigger-ajax-form\">Logout</a></li>\n                                                                    </ul>\n                            </li>\n                        </ul>\n                                                    <form class=\"navbar-form navbar-right form-search\" id=\"form-simple-search\" action=\"/search\">\n                                <fieldset>\n                                     <span class=\"form-control\">\n                                        <i class=\"glyphicon glyphicon-search search-icon\"></i>\n                                         <input type=\"text\" class=\"simple-search-input\" autocomplete=\"off\" name=\"query\"\n                                            data-toggle=\"popover\" data-placement=\"bottom\" data-html=\"true\"\n                                            data-content=\"\n                                                                                                    <i class='fa fa-database'></i> <a href='/yara-search'><span class='lowprio'> YARA Search</span></a><br>\n                                                    <i class='fa fa-database'></i> <a href='/string-search'><span class='lowprio'> String Search</span></a><br>\n                                                                                                                                                    <i class='fa fa-search'></i> <a href='/file-collection/search'><span class='lowprio'> File Collection Search</span></a><br>\n                                                                                                <i class='fa fa-search'></i> <a href='/advanced-search'><span class='lowprio'> Report Search</span></a>\n                                                \" placeholder=\"IP, Domain, Hash&#8230;\">\n                                         <button type=\"reset\" class=\"btn btn-transparent btn-xs\"><i class=\"glyphicon glyphicon-remove\"></i></button>\n                                    </span>\n                                </fieldset>\n                            </form>\n                                            </div>\n                </div>\n            </div>\n                        <div class=\"flash-messages container \">\n                                                                                                                                        <div id=\"hidden-danger-alert-container\" class=\"alert alert-danger\" style=\"display: none\">\n                <button type=\"button\" class=\"close\" data-dismiss=\"alert\" aria-label=\"Close\"><span aria-hidden=\"true\">&times;</span></button>\n                <span></span>\n            </div>\n        </div>\n\n        <div id=\"main-content\">\n                <div id=\"app\" data-server-data=\"{&quot;templateParams&quot;:{&quot;overview&quot;:{&quot;enableAdminButtons&quot;:false,&quot;allowAbuseReport&quot;:true,&quot;enableShareButtons&quot;:true,&quot;enableCommunityScore&quot;:true},&quot;reports&quot;:{&quot;enableReanalysis&quot;:true,&quot;enableDelete&quot;:false,&quot;supportMail&quot;:&quot;support@hybrid-analysis.com&quot;,&quot;urlFalconSandboxProductPage&quot;:&quot;https:\\/\\/www.crowdstrike.com\\/endpoint-security-products\\/falcon-sandbox-malware-analysis\\/&quot;}},&quot;html&quot;:{&quot;downloadButton&quot;:&quot;\\n    \\n                                \\n                                \\n    &lt;a href=\\&quot;#\\&quot; data-href=\\&quot;\\/vetting\\/request?\\&quot;  class=\\&quot;btn btn-default btn-xs vetting-required-button\\&quot;&gt;\\n                    &lt;i class=\\&quot;glyphicon glyphicon-download\\&quot;&gt;&lt;\\/i&gt;\\n                Sample (271KiB)\\n    &lt;\\/a&gt;\\n\\n    \\n\\n&quot;,&quot;fileType&quot;:&quot;&lt;a href=\\&quot;\\/search?query=filetype:peexe&amp;block_redirect=1\\&quot; target=\\&quot;_blank\\&quot; class=\\&quot;file-type\\&quot;&gt;&lt;span class=\\&quot;label label-primary\\&quot;&gt;peexe&lt;\\/span&gt;&lt;\\/a&gt; &lt;a href=\\&quot;\\/search?query=filetype:64bits&amp;block_redirect=1\\&quot; target=\\&quot;_blank\\&quot; class=\\&quot;file-type\\&quot;&gt;&lt;span class=\\&quot;label label-primary\\&quot;&gt;64bits&lt;\\/span&gt;&lt;\\/a&gt; &lt;a href=\\&quot;\\/search?query=filetype:executable&amp;block_redirect=1\\&quot; target=\\&quot;_blank\\&quot; class=\\&quot;file-type\\&quot;&gt;&lt;span class=\\&quot;label label-primary\\&quot;&gt;executable&lt;\\/span&gt;&lt;\\/a&gt; &quot;,&quot;privacyInfo&quot;:null,&quot;facts&quot;:[&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Ready to replace your AV? CrowdStrike is the recognized leader in endpoint protection solutions by industry analysts, independent testing organizations, security professionals, and customers.\\n        &lt;br&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/why-crowdstrike\\/crowdstrike-industry-validation\\/\\&quot;&gt;Industry Recognition and Technology Validation&lt;\\/a&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        What customers are saying about CrowdStrike Falcon Endpoint Protection:&lt;br&gt;\\n        \\&quot;The best product on the market for in term of balance in ease of use, functionality, and effectiveness.\\n        The interface is intuitive and well designed\\&quot;&lt;br&gt;\\n        &lt;br&gt;\\n        \\&quot;Overall this has been a great product and one of the easiest deployments I\\u2019ve been through\\&quot;&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.gartner.com\\/reviews\\/market\\/endpoint-protection-platforms\\/vendor\\/crowdstrike?timeFilter=12\\&quot;&gt;Access Gartner Peer Insights&lt;\\/a&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/customers\\/\\&quot;&gt;Visit CrowdStrike Customer Page&lt;\\/a&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/resources\\/free-trials\\/try-falcon-prevent\\/?ctm_source=Website&amp;ctm_medium=Website_Page&amp;ctm_campaign=Trial_Resources_Page\\&quot;&gt;Access Falcon Prevent Free Trial&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        What Third Party Security Tests and Reviewers are saying about CrowdStrike Falcon Endpoint Protection:&lt;br&gt;\\n        &lt;br&gt;\\n        - &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/why-crowdstrike\\/crowdstrike-industry-validation\\/\\&quot;&gt;Industry Recognition and Technology Validation&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Looking to protect your endpoints? CrowdStrike is Positioned Highest for Ability to Execute and Furthest for\\n        Completeness of Vision in the Visionary Quadrant of the 2024 Gartner Magic Quadrant for Endpoint Protection Platforms&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/resources\\/reports\\/gartner-mq\\/\\&quot;&gt;Download 2024 Gartner MQ Report&lt;\\/a&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/resources\\/free-trials\\/try-falcon-prevent\\/?ctm_source=Website&amp;ctm_medium=Website_Page&amp;ctm_campaign=Trial_Resources_Page\\&quot;&gt;Access Falcon Prevent Free Trial&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Defend the endpoint. Join the world\\u2019s most secure businesses on the first\\n        cloud-native endpoint protection platform built to stop breaches.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/why-crowdstrike-industry-validation\\/\\&quot;&gt;Why CrowdStrike?&lt;\\/a&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/resources\\/free-trials\\/try-falcon-prevent\\/?ctm_source=Website&amp;ctm_medium=Website_Page&amp;ctm_campaign=Trial_Resources_Page\\&quot;&gt;Access Falcon Prevent Free Trial&lt;\\/a&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Tired of manual investigations? CrowdStrike&amp;reg; Falcon Intelligence&amp;trade; eliminates the resource-draining complexity of incident investigations.\\n        Falcon Intelligence automates incident investigations, combining malware sandboxing, malware search, and world class threat intelligence into a single solution.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/products\\/falcon-x\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        CrowdStrike is the first to integrate the tools used by world-class cyber incident investigators\\n        into an endpoint protection platform. CrowdStrike Falcon Intelligence includes the same sandboxing technology used in\\n        hybrid-analysis.com, to investigate threats in minutes, not hours.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/products\\/falcon-x\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Defend against the most relevant threats.\\n        In addition to providing a real time threat feed of global IOCs,\\n        CrowdStrike Falcon Intelligence delivers custom IOCs derived from the automated\\n        malware analysis of threats taken directly from your endpoints.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/products\\/falcon-x\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Stay up to date with research on emerging threats and global adversaries from CrowdStrike\\u2019s Intelligence\\n        experts and make better use of threat intelligence in your organization. &lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/blog\\/category\\/threat-intel-research\\/\\&quot;&gt;CrowdStrike Intelligence Blog&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        You don\\u2019t have a malware problem, you have an adversary problem.\\n        CrowdStrike combines human analysis with a technical data collection platform to provide\\n        threat insights and expose the motivation, intent, TTPs for over 160 identified threat actors and numerous unnamed groups.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/blog\\/category\\/threat-intel-research\\/\\&quot;&gt;CrowdStrike Intelligence Blog&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        CrowdStrike Threat Intelligence reports include YARA and SNORT rules that you can implement in your environment.\\n        All rules are written and tested for false positives by CrowdStrike and available via a web portal and API.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/solutions\\/threat-intelligence-solutions\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        The CrowdStrike Global Threat report provides comprehensive analysis covering dozens of designated adversaries,\\n        providing details about their behavior, capabilities, and intentions related to targeted intrusions,\\n        eCrime, and hacktivist campaigns.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/global-threat-report\\/\\&quot;&gt;Access 2024 CrowdStrike Global Threat Report&lt;\\/a&gt;&lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        CrowdStrike has donated Falcon MalQuery technology to power the \\&quot;YARA search\\&quot; and \\&quot;String search\\&quot; capabilities on Hybrid-Analysis.\\n        If you like what you see, you can easily upgrade to a full MalQuery license,\\n        It includes all features and access to the complete CrowdStrike malware repository consisting of over 1.2+ billion files.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/products\\/falcon-search-engine\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Be alerted when interesting malware samples emerge.\\n        Every day, MalQuery ingests over 750,000 malware samples, you can use YARA to monitor MalQuery\\n        as new samples are added and be alerted via email or API when there is a match.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/products\\/falcon-search-engine\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;,&quot;&lt;blockquote&gt;\\n    &lt;p&gt;\\n        Falcon MalQuery enables users to perform YARA hunts across five years and 1.2+ billion malware samples in seconds.\\n        Find related malware, expose potential attribution and download samples for off-line study.&lt;br&gt;\\n        &lt;br&gt;\\n        &lt;a target=\\&quot;_blank\\&quot; href=\\&quot;https:\\/\\/www.crowdstrike.com\\/products\\/falcon-search-engine\\/\\&quot;&gt;Learn more&lt;\\/a&gt;&lt;br&gt;\\n    &lt;\\/p&gt;\\n&lt;\\/blockquote&gt;\\n&quot;],&quot;commentsForm&quot;:&quot;&lt;form name=\\&quot;community_comment\\&quot; method=\\&quot;post\\&quot; action=\\&quot;\\/community-comment\\/hash\\/3c52178c27d2a0336f6286f6cf0a4a253a507273b1a19303edcacb39d2659a4b\\&quot; novalidate=\\&quot;novalidate\\&quot;&gt;\\n&lt;p&gt;&lt;div id=\\&quot;community_comment\\&quot;&gt;&lt;div class=\\&quot;form-group\\&quot;&gt; &lt;textarea id=\\&quot;community_comment_comment\\&quot; name=\\&quot;community_comment[comment]\\&quot; placeholder=\\&quot;This is an example comment with a #tag ...\\&quot; class=\\&quot;resize-vertically form-control\\&quot; rows=\\&quot;3\\&quot;&gt;&lt;\\/textarea&gt;  &lt;\\/div&gt; &lt;input type=\\&quot;hidden\\&quot; id=\\&quot;community_comment__token\\&quot; name=\\&quot;community_comment[_token]\\&quot; value=\\&quot;d64b2185ab3eb6c3bbb045eded6.ujuedP_Ej4bBR6AUt6H8Tx7akhx3gB5EsNEUCluAO-4.z2PJWcyA46v2P5FnmtDNN1Kx93QO9W4CwLJiaTfjSZ6IUKk_mOm47rBx5Q\\&quot; \\/&gt;&lt;\\/div&gt;&lt;\\/p&gt;\\n&lt;\\/form&gt;\\n&quot;},&quot;av&quot;:{&quot;finishedAgo&quot;:null,&quot;allowRefresh&quot;:false,&quot;data&quot;:[{&quot;name&quot;:&quot;CrowdStrike Falcon&quot;,&quot;type&quot;:&quot;Static Analysis and ML&quot;,&quot;status&quot;:&quot;clean&quot;,&quot;verdictAddon&quot;:null,&quot;vendorUrl&quot;:&quot;https:\\/\\/www.crowdstrike.com\\/products\\/falcon-endpoint-protection\\/&quot;,&quot;hasModal&quot;:false,&quot;reportLink&quot;:null},{&quot;name&quot;:&quot;MetaDefender&quot;,&quot;type&quot;:&quot;Multi Scan Analysis&quot;,&quot;status&quot;:&quot;in progress&quot;,&quot;verdictAddon&quot;:null,&quot;vendorUrl&quot;:&quot;https:\\/\\/www.opswat.com\\/metadefender-core?utm_campaign=Technology%%20Partners&amp;utm_source=HA&quot;,&quot;modalData&quot;:null,&quot;reportLink&quot;:null}],&quot;missingSomeResults&quot;:false,&quot;displaySection&quot;:true},&quot;analysis&quot;:{&quot;sha256&quot;:&quot;3c52178c27d2a0336f6286f6cf0a4a253a507273b1a19303edcacb39d2659a4b&quot;,&quot;submissionName&quot;:&quot;vathos_rev.exe&quot;,&quot;submissionNameWhole&quot;:null,&quot;allSubmissionNames&quot;:[],&quot;size&quot;:&quot;271KiB&quot;,&quot;typeShort&quot;:&quot;64-bit exe&quot;,&quot;type&quot;:&quot;PE32+ executable for MS Windows 6.00 (GUI), x86-64, 14 sections&quot;,&quot;mime&quot;:&quot;application\\/vnd.microsoft.portable-executable&quot;,&quot;isUrlAnalysis&quot;:false,&quot;submissionDate&quot;:&quot;2025-07-17 21:54:19 (UTC)&quot;,&quot;lastAvScanDate&quot;:null,&quot;lastSandboxAnalysisDate&quot;:&quot;2025-07-17 21:54:19 (UTC)&quot;,&quot;verdict&quot;:10,&quot;verdictHuman&quot;:&quot;unknown&quot;,&quot;threatScore&quot;:null,&quot;avDetection&quot;:0,&quot;avFamily&quot;:null,&quot;shortenAvFamily&quot;:null,&quot;tags&quot;:[]},&quot;communityScore&quot;:{&quot;positiveVotes&quot;:0,&quot;negativeVotes&quot;:0,&quot;userVotePositive&quot;:null,&quot;votesDistinction&quot;:&quot;-&quot